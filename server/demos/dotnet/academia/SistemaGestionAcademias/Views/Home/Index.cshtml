@model SistemaGestionAcademias.Models.DashboardViewModel

@{
    ViewData["Title"] = "Panel de Control";
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary shadow-sm border-0 h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase opacity-75 small">Alumnos</h6>
                    <h2 class="fw-bold mb-0">@Model.TotalAlumnos</h2>
                </div>
                <i class="bi bi-people-fill fs-1 opacity-50"></i>
            </div>
            <a asp-controller="Alumnos" asp-action="Index" class="card-footer bg-transparent border-0 text-white small text-decoration-none">Ver Directorio &rarr;</a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success shadow-sm border-0 h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase opacity-75 small">Instructores</h6>
                    <h2 class="fw-bold mb-0">@Model.TotalInstructores</h2>
                </div>
                <i class="bi bi-person-video3 fs-1 opacity-50"></i>
            </div>
            <a asp-controller="Instructores" asp-action="Index" class="card-footer bg-transparent border-0 text-white small text-decoration-none">Ver Equipo &rarr;</a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-dark bg-warning shadow-sm border-0 h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase opacity-75 small">Talleres</h6>
                    <h2 class="fw-bold mb-0">@Model.TotalActividades</h2>
                </div>
                <i class="bi bi-collection-play-fill fs-1 opacity-50"></i>
            </div>
            <a asp-controller="Actividades" asp-action="Index" class="card-footer bg-transparent border-0 text-dark small text-decoration-none">Gestionar &rarr;</a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info shadow-sm border-0 h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase opacity-75 small">Pagos al Día</h6>
                    <h2 class="fw-bold mb-0">@Model.TotalPagados</h2>
                </div>
                <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
            </div>
            <div class="card-footer bg-transparent border-0 text-white small">Matrículas pagadas</div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-calendar-week-fill"></i> Agenda Académica</h6>
                <span class="badge bg-warning text-dark">Clases Activas</span>
            </div>
            <div class="card-body">
                <div id='calendar'></div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-pie-chart-fill"></i> Finanzas</h6>
            </div>
            <div class="card-body d-flex justify-content-center align-items-center">
                <canvas id="chartPagos" style="max-height: 250px;"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <h6 class="fw-bold text-secondary mb-3"><i class="bi bi-bar-chart-fill"></i> Popularidad de Cursos</h6>
        <div style="height: 200px;">
            <canvas id="chartActividades"></canvas>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-clock-history"></i> Actividad Reciente</h6>
        <a asp-controller="Inscripciones" asp-action="Create" class="btn btn-sm btn-dark fw-bold">Nueva Matrícula</a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light small text-uppercase">
                <tr>
                    <th class="ps-4">Fecha</th>
                    <th>Alumno</th>
                    <th>Actividad</th>
                    <th>Estado</th>
                    <th class="text-end pe-4">Acción</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.UltimasInscripciones != null && Model.UltimasInscripciones.Any())
                {
                    @foreach (var item in Model.UltimasInscripciones)
                    {
                        <tr>
                            <td class="ps-4 text-muted small">@item.FechaInscripcion.ToShortDateString()</td>
                            <td class="fw-bold">@item.Alumno?.NombreCompleto</td>
                            <td><span class="badge bg-light text-dark border">@item.Actividad?.Nombre</span></td>
                            <td>
                                @if (item.Estado == "Pagado") {
                                    <span class="badge bg-success-subtle text-success border border-success">Pagado</span>
                                } else {
                                    <span class="badge bg-warning-subtle text-warning border border-warning">@item.Estado</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-controller="Inscripciones" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center py-4 text-muted">Sin datos recientes.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js'></script>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        
        // --- 1. CONFIGURACIÓN DEL CALENDARIO ---
        var calendarEl = document.getElementById('calendar');
        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            locale: 'es', // Idioma español
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,listMonth' // Vista Mes o Lista
            },
            buttonText: {
                today: 'Hoy',
                month: 'Mes',
                list: 'Lista'
            },
            events: '/Home/ObtenerEventosCalendario', // Fuente de datos JSON
            height: 400 // Altura fija
        });
        calendar.render();

        // --- 2. GRÁFICO BARRAS ---
        var etiquetas = @Html.Raw(Json.Serialize(Model.EtiquetasActividades));
        var valores = @Html.Raw(Json.Serialize(Model.ValoresInscritos));
        var ctx1 = document.getElementById('chartActividades').getContext('2d');
        new Chart(ctx1, {
            type: 'bar',
            data: {
                labels: etiquetas,
                datasets: [{
                    label: 'Alumnos',
                    data: valores,
                    backgroundColor: '#0d6efd',
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
            }
        });

        // --- 3. GRÁFICO DONA ---
        var ctx2 = document.getElementById('chartPagos').getContext('2d');
        new Chart(ctx2, {
            type: 'doughnut',
            data: {
                labels: ['Pagado', 'Pendiente'],
                datasets: [{
                    data: [@Model.TotalPagados, @Model.TotalPendientes],
                    backgroundColor: ['#198754', '#ffc107'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } }
            }
        });
    });
</script>