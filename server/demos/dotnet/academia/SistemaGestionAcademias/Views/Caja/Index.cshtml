@model SistemaGestionAcademias.Models.CajaDiaria
@inject SistemaGestionAcademias.Services.ConfiguracionService ConfigService
@{
    ViewData["Title"] = "Control de Caja";
    var config = await ConfigService.ObtenerConfiguracion();
    
    // Variables de estado y totales calculados en el controlador
    var estado = ViewData["EstadoCaja"] as string;
    var esCerrada = estado == "Cerrada";
    decimal saldoTeorico = ViewBag.SaldoTeoricoEfectivo ?? 0;
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-4">
    <div>
        <h2 class="fw-bold text-dark"><i class="bi bi-cash-coin"></i> Flujo de Caja</h2>
        <p class="text-muted mb-0">
            Estado: 
            @if(esCerrada){ <span class="badge bg-danger">CERRADA</span> } 
            else { <span class="badge bg-success">ABIERTA</span> }
            | Fecha: @Model.Fecha.ToShortDateString()
        </p>
    </div>
    
    <div>
        @if (!esCerrada)
        {
            <button class="btn btn-outline-danger me-2 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#modalGasto">
                <i class="bi bi-dash-circle"></i> Registrar Gasto
            </button>
            
            <a asp-action="Cerrar" asp-route-id="@Model.Id" class="btn btn-dark fw-bold shadow-sm">
                <i class="bi bi-lock-fill"></i> Cerrar Caja
            </a>
        }
        else 
        {
             <div class="alert alert-secondary py-1 px-3 mb-0 fw-bold border-secondary text-secondary">
                <i class="bi bi-check-all"></i> Jornada Finalizada
            </div>
        }
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card bg-white border shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted small text-uppercase fw-bold">Apertura (Sencillo)</h6>
                <h3 class="fw-bold text-secondary">@config.MonedaSimbolo @Model.MontoInicial.ToString("N2")</h3>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card bg-success text-white shadow border-0 h-100">
            <div class="card-body">
                <h6 class="text-uppercase opacity-75 small fw-bold"><i class="bi bi-arrow-up"></i> Ingresos Totales</h6>
                <h3 class="fw-bold">@config.MonedaSimbolo @ViewBag.TotalIngresos.ToString("N2")</h3>
                <div class="small opacity-75 mt-1" style="font-size: 0.8rem;">
                    Efectivo: @ViewBag.TotalEfectivo.ToString("N0") <br> 
                    Digital/Bancos: @ViewBag.TotalDigital.ToString("N0")
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-danger text-white shadow border-0 h-100">
            <div class="card-body">
                <h6 class="text-uppercase opacity-75 small fw-bold"><i class="bi bi-arrow-down"></i> Gastos / Salidas</h6>
                <h3 class="fw-bold">@config.MonedaSimbolo @ViewBag.TotalGastos.ToString("N2")</h3>
                <small class="opacity-75">Salidas registradas</small>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-dark text-white shadow border-0 h-100">
            <div class="card-body">
                <h6 class="text-uppercase opacity-75 small fw-bold">Efectivo en Cajón (Teórico)</h6>
                <h3 class="fw-bold text-warning">@config.MonedaSimbolo @saldoTeorico.ToString("N2")</h3>
                <small class="text-muted" style="font-size: 0.75rem;">(Inicial + Ingresos Efec. - Gastos)</small>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-7">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-bold text-success border-bottom">
                <i class="bi bi-plus-circle"></i> Ingresos (Matrículas)
            </div>
            <div class="table-responsive" style="max-height: 400px; overflow-y:auto;">
                <table class="table table-hover table-sm mb-0 small align-middle">
                    <thead class="bg-light sticky-top">
                        <tr>
                            <th class="ps-3">Alumno</th>
                            <th>Método Pago</th>
                            <th class="text-end pe-3">Monto</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.ListaIngresos != null)
                        {
                            foreach(var item in ViewBag.ListaIngresos)
                            {
                                <tr>
                                    <td class="ps-3 py-2">
                                        <div class="fw-bold">@item.Alumno.NombreCompleto</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">@item.Actividad.Nombre</div>
                                    </td>
                                    <td>
                                        @if(item.MetodoPago == "Efectivo") { <span class="badge bg-success bg-opacity-10 text-success border border-success">Efectivo</span> }
                                        else { <span class="badge bg-primary bg-opacity-10 text-primary border border-primary">@item.MetodoPago</span> }
                                    </td>
                                    <td class="text-end pe-3 fw-bold">@item.MontoFinal.ToString("N2")</td>
                                </tr> }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-bold text-danger border-bottom">
                <i class="bi bi-dash-circle"></i> Salidas (Gastos)
            </div>
            <div class="table-responsive" style="max-height: 400px; overflow-y:auto;">
                <table class="table table-hover table-sm mb-0 small align-middle">
                    <thead class="bg-light sticky-top">
                        <tr>
                            <th class="ps-3">Concepto</th>
                            <th class="text-end pe-3">Monto</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.ListaGastos != null)
                        {
                            foreach(var item in ViewBag.ListaGastos)
                            {
                                <tr>
                                    <td class="ps-3 py-2">
                                        <div class="fw-bold text-dark">@item.Descripcion</div>
                                        <small class="text-muted">@item.FechaHora.ToString("HH:mm") - @item.RegistradoPor</small>
                                    </td>
                                    <td class="text-end pe-3 text-danger fw-bold">- @item.Monto.ToString("N2")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                @if(ViewBag.TotalGastos == 0) {
                    <div class="text-center p-4 text-muted">
                        <i class="bi bi-wallet2 display-6 opacity-25"></i>
                        <p class="mt-2 mb-0">No hay gastos registrados hoy.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalGasto" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-dash-circle"></i> Registrar Salida de Dinero</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RegistrarGasto" method="post">
                <div class="modal-body p-4">
                    <div class="alert alert-warning small d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <div>El dinero se descontará del <strong>Efectivo en Caja</strong>.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Concepto / Descripción</label>
                        <input type="text" name="descripcion" class="form-control" placeholder="Ej: Compra de útiles, Pago de limpieza..." required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Monto a retirar</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-danger fw-bold">@config.MonedaSimbolo</span>
                            <input type="number" name="monto" class="form-control border-danger" step="0.01" min="0.1" placeholder="0.00" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger fw-bold shadow-sm">Confirmar Gasto</button>
                </div>
            </form>
        </div>
    </div>
</div>