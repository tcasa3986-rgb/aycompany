@model SistemaGestionAcademias.Models.Instructor

@{
    ViewData["Title"] = "Nuevo Instructor";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow border-0">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="bi bi-person-plus-fill"></i> Registrar Nuevo Instructor</h4>
            </div>
            <div class="card-body bg-light">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Nombres" class="form-label fw-bold">Nombres</label>
                            <input asp-for="Nombres" class="form-control" placeholder="Ej: Roberto" autofocus />
                            <span asp-validation-for="Nombres" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Apellidos" class="form-label fw-bold">Apellidos</label>
                            <input asp-for="Apellidos" class="form-control" placeholder="Ej: Gómez Bolaños" />
                            <span asp-validation-for="Apellidos" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Especialidad" class="form-label fw-bold">Especialidad / Título</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-award"></i></span>
                            <input asp-for="Especialidad" class="form-control" placeholder="Ej: Profesor de Matemáticas, Pianista..." />
                        </div>
                        <span asp-validation-for="Especialidad" class="text-danger small"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label fw-bold">Teléfono / Celular</label>
                            <input asp-for="Telefono" class="form-control" />
                            <span asp-validation-for="Telefono" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Correo" class="form-label fw-bold">Correo Electrónico</label>
                            <input asp-for="Correo" class="form-control" placeholder="nombre@academia.com" />
                            <span asp-validation-for="Correo" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch p-3 bg-white border rounded">
                            <input class="form-check-input ms-0 me-2" asp-for="Activo" checked />
                            <label class="form-check-label fw-bold" asp-for="Activo">
                                &nbsp;&nbsp; Instructor Activo (Disponible para asignar cursos)
                            </label>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a asp-action="Index" class="btn btn-secondary me-2">Cancelar</a>
                        <button type="submit" class="btn btn-success fw-bold px-4">Guardar Instructor</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}