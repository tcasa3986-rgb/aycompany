@model IEnumerable<SistemaGestionAcademias.Models.Instructor>

@{
    ViewData["Title"] = "Directorio de Instructores";
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <h4 class="mb-0 text-success"><i class="bi bi-person-video3"></i> Directorio de Instructores</h4>
        <a asp-action="Create" class="btn btn-success rounded-pill px-4">
            <i class="bi bi-person-plus-fill"></i> Nuevo Instructor
        </a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0 align-middle">
            <thead class="bg-light text-secondary">
                <tr>
                    <th class="ps-4">Instructor</th>
                    <th>Especialidad</th>
                    <th>Contacto</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-dark">@item.Nombres @item.Apellidos</div>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border">@item.Especialidad</span>
                        </td>
                        <td class="small">
                            <div><i class="bi bi-envelope"></i> @item.Correo</div>
                            <div class="text-muted"><i class="bi bi-telephone"></i> @item.Telefono</div>
                        </td>
                        <td>
                            @if(item.Activo) {
                                <span class="badge bg-success">Activo</span>
                            } else {
                                <span class="badge bg-danger">Inactivo</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                
                                @if (item.Activo)
                                {
                                    <a asp-action="ToggleStatus" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Desactivar / Dar de baja">
                                        <i class="bi bi-person-dash-fill"></i>
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="ToggleStatus" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success" title="Reactivar">
                                        <i class="bi bi-person-check-fill"></i>
                                    </a>
                                }

                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Editar Datos"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Ver Perfil"><i class="bi bi-eye"></i></a>
                                
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Eliminar"><i class="bi bi-trash"></i></a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>