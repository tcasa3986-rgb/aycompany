@model SistemaGestionAcademias.Models.Categoria

@{
    ViewData["Title"] = "Nueva Categoría";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6"> <div class="card shadow border-0">
            <div class="card-header bg-info text-white py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-tag-fill"></i> Crear Nueva Categoría</h4>
            </div>
            
            <div class="card-body bg-light p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-bold">Nombre de Categoría</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej: Deportes, Arte, Tecnología..." autofocus />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label fw-bold">Descripción</label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Breve descripción de qué trata esta categoría..."></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger small"></span>
                    </div>

                    <div class="form-check form-switch p-3 bg-white border rounded mb-3">
                        <input class="form-check-input ms-0 me-2" asp-for="Estado" checked />
                        <label class="form-check-label fw-bold" asp-for="Estado">
                            &nbsp;&nbsp; Categoría Activa
                        </label>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a asp-action="Index" class="btn btn-secondary me-2">Cancelar</a>
                        <button type="submit" class="btn btn-info text-white fw-bold px-4">Guardar Categoría</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}