@model IEnumerable<SistemaGestionAcademias.Models.Actividad>

@{
    ViewData["Title"] = "Gestión de Actividades";
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <h4 class="mb-0 text-warning fw-bold" style="color: #d68c00 !important;"><i class="bi bi-collection-play-fill"></i> Catálogo de Talleres</h4>
        <a asp-action="Create" class="btn btn-warning rounded-pill px-4 shadow-sm fw-bold">
            <i class="bi bi-plus-lg"></i> Nueva Actividad
        </a>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0 align-middle">
            <thead class="bg-light text-secondary">
                <tr>
                    <th class="ps-4">Actividad</th>
                    <th>Categoría</th>
                    <th>Instructor</th>
                    <th>Cupos</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-dark">@item.Nombre</div>
                            <small class="text-muted">Inicio: @item.FechaInicio.ToShortDateString()</small>
                        </td>
                        <td><span class="badge bg-light text-dark border">@item.Categoria?.Nombre</span></td>
                        <td>@item.Instructor?.Nombres @item.Instructor?.Apellidos</td>
                        <td>
                            @{ var inscritos = item.Inscripciones?.Count ?? 0; }
                            <span class="badge bg-secondary">@inscritos / @item.CupoMaximo</span>
                        </td>
                        <td>
                            @if(item.Activo) {
                                <span class="badge bg-success">Abierto</span>
                            } else {
                                <span class="badge bg-danger">Cerrado</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Ver Detalles"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Editar"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Eliminar"><i class="bi bi-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>