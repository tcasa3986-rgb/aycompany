@model SistemaGestionAcademias.Models.Actividad
@inject SistemaGestionAcademias.Services.ConfiguracionService ConfigService
@{
    ViewData["Title"] = "Nueva Actividad y Cronograma";
    var config = await ConfigService.ObtenerConfiguracion();
}

<div class="row justify-content-center mt-4">
    <div class="col-md-10">
        <div class="card shadow border-0">
            <div class="card-header bg-warning text-dark py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-calendar-week"></i> Crear Actividad y Cronograma</h4>
            </div>
            <div class="card-body bg-light p-4">
                <form asp-action="Create" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row mb-4">
                        <div class="col-md-4 text-center">
                            <label class="form-label fw-bold mb-2">Portada del Curso</label>
                            <div class="border rounded bg-white p-2 d-flex align-items-center justify-content-center shadow-sm" style="height: 150px;">
                                <img id="previewImg" src="#" style="max-height: 100%; max-width: 100%; display: none;" class="rounded" />
                                <div id="previewIcon" class="text-muted text-center">
                                    <i class="bi bi-image display-4"></i><br>Sin Imagen
                                </div>
                            </div>
                            <input type="file" name="imagen" class="form-control mt-2" accept="image/*" onchange="mostrarVistaPrevia(this)" />
                        </div>
                        <div class="col-md-8">
                            <label asp-for="Nombre" class="form-label fw-bold">Nombre del Taller</label>
                            <input asp-for="Nombre" class="form-control form-control-lg mb-3" placeholder="Ej: Fútbol Verano" autofocus />
                            
                            <label asp-for="Costo" class="form-label fw-bold text-success"><i class="bi bi-cash-stack"></i> Costo</label>
                            <div class="input-group">
                                <span class="input-group-text bg-success text-white border-success fw-bold">@config.MonedaSimbolo</span>
                                <input asp-for="Costo" class="form-control form-control-lg border-success" type="number" step="0.01" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="CategoriaId" class="form-label fw-bold">Categoría</label>
                            <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.CategoriaId"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="InstructorId" class="form-label fw-bold">Instructor</label>
                            <select asp-for="InstructorId" class="form-select" asp-items="ViewBag.InstructorId"></select>
                        </div>
                    </div>

                    <div class="card mb-4 border-primary shadow-sm">
                        <div class="card-header bg-primary text-white fw-bold">
                            <i class="bi bi-clock-history"></i> Configuración del Cronograma
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Días de Clase (Marcar)</label>
                                    <div class="d-flex flex-wrap gap-2">
                                        <div class="btn-group" role="group">
                                            <input type="checkbox" class="btn-check dia-check" id="diaLunes" value="Lunes" autocomplete="off">
                                            <label class="btn btn-outline-primary" for="diaLunes">Lun</label>

                                            <input type="checkbox" class="btn-check dia-check" id="diaMartes" value="Martes" autocomplete="off">
                                            <label class="btn btn-outline-primary" for="diaMartes">Mar</label>

                                            <input type="checkbox" class="btn-check dia-check" id="diaMiercoles" value="Miércoles" autocomplete="off">
                                            <label class="btn btn-outline-primary" for="diaMiercoles">Mié</label>

                                            <input type="checkbox" class="btn-check dia-check" id="diaJueves" value="Jueves" autocomplete="off">
                                            <label class="btn btn-outline-primary" for="diaJueves">Jue</label>

                                            <input type="checkbox" class="btn-check dia-check" id="diaViernes" value="Viernes" autocomplete="off">
                                            <label class="btn btn-outline-primary" for="diaViernes">Vie</label>
                                            
                                            <input type="checkbox" class="btn-check dia-check" id="diaSabado" value="Sábado" autocomplete="off">
                                            <label class="btn btn-outline-primary" for="diaSabado">Sáb</label>
                                        </div>
                                    </div>
                                    <input type="hidden" asp-for="DiasSemana" id="inputDiasSemana" />
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="HoraInicio" class="form-label fw-bold">Hora Inicio</label>
                                    <input asp-for="HoraInicio" class="form-control" type="time" onchange="calcularHoras()" />
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="HoraFin" class="form-label fw-bold">Hora Fin</label>
                                    <input asp-for="HoraFin" class="form-control" type="time" onchange="calcularHoras()" />
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <label asp-for="FechaInicio" class="form-label fw-bold">Fecha Inicio del Curso</label>
                                    <input asp-for="FechaInicio" class="form-control" type="date" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="FechaFin" class="form-label fw-bold">Fecha Fin del Curso</label>
                                    <input asp-for="FechaFin" class="form-control" type="date" />
                                </div>
                            </div>
                            
                            <div class="mt-3 alert alert-info py-2 small">
                                <i class="bi bi-info-circle"></i> Total Horas Calculadas (aprox): <strong id="lblTotalHoras">0</strong> hrs.
                                <input type="hidden" asp-for="TotalHoras" id="inputTotalHoras" />
                            </div>
                        </div>
                    </div>

                    <div class="card mb-4 border-secondary shadow-sm">
                        <div class="card-header bg-white fw-bold text-muted border-bottom">
                            <i class="bi bi-journal-text"></i> Detalles Académicos
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label asp-for="Descripcion" class="form-label fw-bold">Descripción General</label>
                                <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Silabus" class="form-label fw-bold">Temario / Sílabus</label>
                                    <textarea asp-for="Silabus" class="form-control" rows="3"></textarea>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Objetivos" class="form-label fw-bold">Objetivos</label>
                                    <textarea asp-for="Objetivos" class="form-control" rows="3"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="CupoMaximo" class="form-label fw-bold">Cupo Máximo</label>
                            <input asp-for="CupoMaximo" class="form-control" type="number" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check form-switch p-2 bg-white border rounded w-100">
                                <input class="form-check-input ms-0 me-2" asp-for="Activo" checked />
                                <label class="form-check-label fw-bold" asp-for="Activo">Actividad Abierta</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a asp-action="Index" class="btn btn-secondary me-2">Cancelar</a>
                        <button type="submit" class="btn btn-warning fw-bold px-4">Guardar y Generar Cronograma</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function mostrarVistaPrevia(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#previewIcon').hide();
                    $('#previewImg').attr('src', e.target.result).show();
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        $(document).ready(function() {
            $('select').select2({ theme: 'bootstrap-5', width: '100%' });

            // Lógica para capturar días seleccionados
            $('.dia-check').change(function() {
                var dias = [];
                $('.dia-check:checked').each(function() {
                    dias.push($(this).val());
                });
                $('#inputDiasSemana').val(dias.join(','));
                calcularHoras(); // Recalcular si cambia algo (opcional)
            });
        });

        function calcularHoras() {
            // Lógica simple para estimar horas (HoraFin - HoraInicio) * Semanas
            // Esto es visual, el cálculo real podría ser más complejo en backend
            var inicio = document.getElementById("HoraInicio").value;
            var fin = document.getElementById("HoraFin").value;
            
            if(inicio && fin) {
                var d1 = new Date("2000-01-01 " + inicio);
                var d2 = new Date("2000-01-01 " + fin);
                var diff = (d2 - d1) / 1000 / 60 / 60; // Horas por día
                
                if(diff > 0) {
                    var numDias = $('.dia-check:checked').length;
                    var total = Math.round(diff * numDias * 4); // Estimado x 4 semanas (1 mes)
                    // Solo para mostrar algo referencial
                    $('#lblTotalHoras').text(total);
                    $('#inputTotalHoras').val(total);
                }
            }
        }
    </script>
}