@using Microsoft.AspNetCore.Identity
@using SistemaGestionAcademias.Areas.Identity.Pages.Account.Manage
@inject SignInManager<IdentityUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}

<div class="list-group">
    <a id="profile" asp-page="./Index" class="list-group-item list-group-item-action @ManageNavPages.IndexNavClass(ViewContext) fw-bold">
        <i class="bi bi-person-vcard me-2"></i> Datos Personales
    </a>
    
    <a id="email" asp-page="./Email" class="list-group-item list-group-item-action @ManageNavPages.EmailNavClass(ViewContext) fw-bold">
        <i class="bi bi-envelope-at me-2"></i> Correo Electrónico
    </a>
    
    <a id="change-password" asp-page="./ChangePassword" class="list-group-item list-group-item-action @ManageNavPages.ChangePasswordNavClass(ViewContext) fw-bold">
        <i class="bi bi-key me-2"></i> Contraseña
    </a>

    @if (hasExternalLogins)
    {
        <a id="external-login" asp-page="./ExternalLogins" class="list-group-item list-group-item-action @ManageNavPages.ExternalLoginsNavClass(ViewContext) fw-bold">
            <i class="bi bi-google me-2"></i> Accesos Externos
        </a>
    }
    
    <a id="two-factor" asp-page="./TwoFactorAuthentication" class="list-group-item list-group-item-action @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext) fw-bold">
        <i class="bi bi-shield-lock me-2"></i> Seguridad 2FA
    </a>
    
    <a id="personal-data" asp-page="./PersonalData" class="list-group-item list-group-item-action @ManageNavPages.PersonalDataNavClass(ViewContext) fw-bold text-danger">
        <i class="bi bi-trash3 me-2"></i> Zona de Peligro
    </a>
</div>