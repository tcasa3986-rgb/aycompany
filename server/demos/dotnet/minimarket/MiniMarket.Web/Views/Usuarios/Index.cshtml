@model IEnumerable<MiniMarket.Web.Models.UsuarioViewModel>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-primary"><i class="fas fa-user-shield me-2"></i>Usuarios del Sistema</h2>
        <p class="text-muted">Administra los accesos y roles del personal.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="fas fa-user-plus me-2"></i> NUEVO USUARIO
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle" id="tablaUsuarios">
                <thead class="bg-light">
                    <tr>
                        <th>Email / Usuario</th>
                        <th>Rol Asignado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">
                                <i class="fas fa-user-circle text-muted me-2"></i>@item.Email
                            </td>
                            <td>
                                @if (item.Rol == "Administrador")
                                {
                                    <span class="badge bg-danger">ADMINISTRADOR</span>
                                }
                                else if (item.Rol == "Cajero")
                                {
                                    <span class="badge bg-success">CAJERO</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Rol</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                @if (item.Email != User.Identity.Name)
                                {
                                    <button class="btn btn-sm btn-outline-danger ms-1 btn-eliminar"
                                            data-id="@item.Id" data-email="@item.Email" title="Eliminar">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                    <form id="formDelete_@item.Id" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:none;">
                                        @Html.AntiForgeryToken()
                                    </form>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted ms-1">(Tú)</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            $('#tablaUsuarios').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json' }
            });

            $(document).on('click', '.btn-eliminar', function() {
                var id = $(this).data('id');
                var email = $(this).data('email');

                Swal.fire({
                    title: '¿Eliminar usuario?',
                    html: `<p>Se eliminará permanentemente: <strong>${email}</strong></p>`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, eliminar',
                    confirmButtonColor: '#dc3545',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("Delete", "Usuarios")',
                            type: 'POST',
                            data: {
                                id: id,
                                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').first().val()
                            },
                            success: function(resp) {
                                if (resp.exito) {
                                    Swal.fire('¡Eliminado!', resp.mensaje, 'success').then(() => location.reload());
                                } else {
                                    Swal.fire('Error', resp.mensaje, 'error');
                                }
                            },
                            error: function() { Swal.fire('Error', 'Error de conexión', 'error'); }
                        });
                    }
                });
            });
        });
    </script>
}