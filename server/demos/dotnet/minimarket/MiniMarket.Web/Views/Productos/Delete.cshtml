@using MiniMarket.Web.Data
@inject ApplicationDbContext _context
@model MiniMarket.Web.Models.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
    var config = _context.Configuraciones.FirstOrDefault();
    string moneda = config != null ? config.MonedaSimbolo : "S/.";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="fas fa-exclamation-triangle me-2"></i>¿Confirmar Eliminación?
                    </h5>
                </div>
                
                <div class="card-body p-4">
                    <div class="alert alert-warning border-0 bg-warning bg-opacity-10 text-dark mb-4">
                        <i class="fas fa-info-circle me-1"></i>
                        Esta acción es irreversible. El producto será eliminado del inventario permanentemente.
                    </div>

                    <div class="d-flex align-items-center mb-4 p-3 border rounded bg-light">
                        <div class="me-4">
                            @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                            {
                                <img src="@Model.ImagenUrl" class="rounded border bg-white" style="width: 100px; height: 100px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="rounded border bg-white d-flex align-items-center justify-content-center text-muted" style="width: 100px; height: 100px;">
                                    <i class="fas fa-box fa-2x"></i>
                                </div>
                            }
                        </div>
                        
                        <div>
                            <h4 class="fw-bold text-dark mb-1">@Model.Nombre</h4>
                            <span class="badge bg-secondary mb-2">@Model.Categoria?.Nombre</span>
                            <div class="text-muted small">
                                Stock actual: <strong>@Model.Stock unidades</strong>
                            </div>
                            <div class="text-danger fw-bold fs-5 mt-1">
                                @moneda @Model.Precio.ToString("N2")
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" class="d-flex justify-content-end gap-2">
                        <input type="hidden" asp-for="Id" />
                        <a asp-action="Index" class="btn btn-secondary">
                            Cancelar
                        </a>
                        <button type="submit" class="btn btn-danger fw-bold">
                            <i class="fas fa-trash-alt me-2"></i> Sí, Eliminar Producto
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>