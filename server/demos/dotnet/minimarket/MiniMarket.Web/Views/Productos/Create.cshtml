@model MiniMarket.Web.Models.Producto

@{
    ViewData["Title"] = "Nuevo Producto";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-box-open me-2"></i>Registrar Producto</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="Nombre" class="form-label fw-bold">Nombre del Producto</label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: Arroz Costeño 1kg" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="CodigoBarras" class="form-label fw-bold">Código de Barras</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-barcode"></i></span>
                                <input asp-for="CodigoBarras" class="form-control" placeholder="Escanear..." />
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label">Descripción</label>
                        <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CategoriaId" class="form-label fw-bold">Categoría</label>
                            <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.CategoriaId"></select>
                        </div>
                        <div class="col-md-6 mb-3">
                             <label class="form-label fw-bold">Imagen del Producto</label>
                             <input type="file" name="imagenArchivo" class="form-control" accept="image/*" />
                        </div>
                    </div>

                    <div class="row bg-light p-3 rounded mb-3 border">
                        <div class="col-12 mb-2 border-bottom pb-2">
                            <h6 class="text-primary fw-bold mb-0">Precios y Stock</h6>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="Precio" class="form-label fw-bold text-success">Precio Venta</label>
                            <input asp-for="Precio" type="number" step="0.01" class="form-control fw-bold" />
                            <span asp-validation-for="Precio" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="Costo" class="form-label text-muted">Costo Compra</label>
                            <input asp-for="Costo" type="number" step="0.01" class="form-control" />
                        </div>
                        
                        <div class="col-md-3 mb-3">
                            <label asp-for="Stock" class="form-label fw-bold">Stock Inicial</label>
                            <input asp-for="Stock" type="number" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="StockMinimo" class="form-label fw-bold text-danger">Stock Mínimo</label>
                            <input asp-for="StockMinimo" type="number" class="form-control border-danger" title="Alerta cuando baje de esta cantidad" />
                        </div>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input class="form-check-input" type="checkbox" asp-for="Estado" />
                        <label class="form-check-label" asp-for="Estado">Producto Activo (Disponible para venta)</label>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-primary px-5"><i class="fas fa-save me-2"></i>Guardar Producto</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}