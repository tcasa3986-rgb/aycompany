@model MiniMarket.Web.Models.Producto

@{
    ViewData["Title"] = "Editar Producto";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow border-0">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Editar Producto</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="Nombre" class="form-label fw-bold">Nombre</label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="CodigoBarras" class="form-label fw-bold">Código Barras</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-barcode"></i></span>
                                <input asp-for="CodigoBarras" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label">Descripción</label>
                        <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="row align-items-center mb-3">
                        <div class="col-md-6">
                            <label asp-for="CategoriaId" class="form-label fw-bold">Categoría</label>
                            <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.CategoriaId"></select>
                        </div>
                        <div class="col-md-6">
                             <label class="form-label fw-bold">Imagen</label>
                             <input type="file" name="imagenArchivo" class="form-control mb-2" accept="image/*" />
                             
                             @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                             {
                                 <div class="p-2 border rounded bg-light text-center">
                                     <img src="@Model.ImagenUrl" alt="Imagen actual" style="max-height: 80px;" class="img-fluid rounded" />
                                     <small class="d-block text-muted">Imagen actual</small>
                                 </div>
                             }
                        </div>
                    </div>

                    <div class="row bg-light p-3 rounded mb-3 border">
                        <div class="col-md-3 mb-3">
                            <label asp-for="Precio" class="form-label fw-bold text-success">Precio</label>
                            <input asp-for="Precio" type="number" step="0.01" class="form-control fw-bold" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="Costo" class="form-label text-muted">Costo</label>
                            <input asp-for="Costo" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="Stock" class="form-label fw-bold">Stock</label>
                            <input asp-for="Stock" type="number" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="StockMinimo" class="form-label fw-bold text-danger">Mínimo</label>
                            <input asp-for="StockMinimo" type="number" class="form-control border-danger" />
                        </div>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input class="form-check-input" type="checkbox" asp-for="Estado" />
                        <label class="form-check-label" asp-for="Estado">Producto Activo</label>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-warning px-5"><i class="fas fa-save me-2"></i>Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}