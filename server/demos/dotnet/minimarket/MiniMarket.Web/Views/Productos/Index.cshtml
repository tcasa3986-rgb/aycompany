@model IEnumerable<MiniMarket.Web.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary"><i class="fas fa-boxes me-2"></i>Catálogo de Productos</h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="fas fa-plus me-2"></i> Nuevo Producto</a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle" id="tablaProductos">
                <thead class="bg-light">
                    <tr>
                        <th style="width: 80px;">Img</th>
                        <th>Producto / Código</th>
                        <th>Categoría</th>
                        <th class="text-end">Precio</th>
                        <th class="text-center">Stock</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.Estado ? "" : "text-muted opacity-75")">
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImagenUrl))
                                {
                                    <img src="@item.ImagenUrl" class="rounded border" style="width: 50px; height: 50px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light rounded border d-flex align-items-center justify-content-center text-muted" style="width: 50px; height: 50px;">
                                        <i class="fas fa-image"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-bold">@item.Nombre</div>
                                <small class="text-muted"><i class="fas fa-barcode me-1"></i>@item.CodigoBarras</small>
                            </td>
                            <td>
                                <span class="badge bg-info text-dark">@item.Categoria.Nombre</span>
                            </td>
                            <td class="text-end fw-bold text-success">
                                S/. @item.Precio.ToString("N2")
                            </td>
                            <td class="text-center">
                                @if (item.Stock <= item.StockMinimo)
                                {
                                    <span class="badge bg-danger rounded-pill shadow-sm" title="Stock bajo (Mín: @item.StockMinimo)">
                                        <i class="fas fa-exclamation-triangle me-1"></i>@item.Stock
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark border">@item.Stock</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.Estado)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Detalles">
                                    <i class="fas fa-eye"></i>
                                </a>
                                @if (item.Estado)
                                {
                                    <a asp-action="CambiarEstado" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Desactivar" onclick="return confirm('¿Desactivar este producto? Ya no aparecerá en el punto de venta.');">
                                        <i class="fas fa-power-off"></i>
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="CambiarEstado" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success" title="Activar">
                                        <i class="fas fa-check"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaProductos').DataTable({
                language: { url: "//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json" }
            });
        });
    </script>
}