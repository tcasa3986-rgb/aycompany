@model MiniMarket.Web.Models.ConfiguracionViewModel
@{
    ViewData["Title"] = "Configuración del Sistema";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-primary"><i class="fas fa-cogs me-2"></i>Configuración</h2>
        <p class="text-muted">Datos generales de la empresa para reportes y tickets.</p>
    </div>
</div>

@if (TempData["MensajeExito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["MensajeExito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow border-0 mb-4">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-building me-2"></i>Datos de la Empresa</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Guardar" method="post" enctype="multipart/form-data">
                    <div class="row mb-3">
                        <div class="col-md-7">
                            <label asp-for="NombreEmpresa" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-store"></i></span>
                                <input asp-for="NombreEmpresa" class="form-control" placeholder="Ej: Mi Bodega SAC" />
                            </div>
                            <span asp-validation-for="NombreEmpresa" class="text-danger small"></span>
                        </div>
                        <div class="col-md-5">
                            <label asp-for="Ruc" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-id-card"></i></span>
                                <input asp-for="Ruc" class="form-control" placeholder="11 dígitos" maxlength="11" />
                            </div>
                            <span asp-validation-for="Ruc" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Direccion" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="fas fa-map-marker-alt"></i></span>
                            <input asp-for="Direccion" class="form-control" />
                        </div>
                        <span asp-validation-for="Direccion" class="text-danger small"></span>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-phone"></i></span>
                                <input asp-for="Telefono" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EmailContacto" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-envelope"></i></span>
                                <input asp-for="EmailContacto" type="email" class="form-control" />
                            </div>
                            <span asp-validation-for="EmailContacto" class="text-danger small"></span>
                        </div>
                    </div>

                    <h5 class="mb-3 fw-bold text-dark border-top pt-3"><i class="fas fa-sliders-h me-2"></i>Parámetros del Sistema</h5>
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <label asp-for="IgvPorcentaje" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <input asp-for="IgvPorcentaje" type="number" step="0.01" class="form-control fw-bold text-end" />
                                <span class="input-group-text bg-light fw-bold">%</span>
                            </div>
                            <span asp-validation-for="IgvPorcentaje" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MonedaSimbolo" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-coins"></i></span>
                                <input asp-for="MonedaSimbolo" class="form-control" placeholder="S/." />
                            </div>
                            <span asp-validation-for="MonedaSimbolo" class="text-danger small"></span>
                        </div>
                    </div>
                    
                    <h5 class="mb-3 fw-bold text-dark border-top pt-3"><i class="fas fa-image me-2"></i>Imagen Visual</h5>
                    <div class="row mb-4 align-items-center">
                        <div class="col-md-8">
                            <label asp-for="LogoUpload" class="form-label fw-bold"></label>
                            <input asp-for="LogoUpload" type="file" class="form-control" accept="image/*" />
                            <small class="text-muted d-block mt-1">Recomendado: Imagen PNG o JPG transparente no muy grande.</small>
                        </div>
                        <div class="col-md-4 text-center">
                            @if (!string.IsNullOrEmpty(Model.CurrentLogoUrl))
                            {
                                <div class="bg-light p-2 rounded border mt-2 mt-md-0 d-inline-block">
                                    <img src="@Model.CurrentLogoUrl" alt="Logo actual" style="max-height: 80px; max-width: 100%; object-fit: contain;" />
                                </div>
                            }
                            else
                            {
                                <div class="bg-light p-3 rounded border text-muted mt-2 mt-md-0">
                                    <i class="fas fa-image fa-2x mb-2 opacity-50"></i><br>
                                    <small>Sin logo definido</small>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm">
                            <i class="fas fa-save me-2"></i> Guardar Cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card bg-primary bg-opacity-10 border-0 shadow-sm text-primary mb-3">
            <div class="card-body">
                <h6 class="fw-bold"><i class="fas fa-info-circle me-2"></i>¿Para qué sirve esto?</h6>
                <p class="small mb-0 text-dark">
                    La información que ingreses aquí será utilizada para personalizar el encabezado de tus <strong>Tickets de Venta</strong> y otros reportes oficiales del sistema.
                </p>
            </div>
        </div>
        <div class="card border-0 shadow-sm">
             <div class="card-body text-center text-muted p-4">
                 <i class="fas fa-print fa-3x mb-3 opacity-25"></i>
                 <p class="small mb-0">Asegúrate de que el RUC y la Dirección sean correctos para evitar problemas en la impresión de comprobantes.</p>
             </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}