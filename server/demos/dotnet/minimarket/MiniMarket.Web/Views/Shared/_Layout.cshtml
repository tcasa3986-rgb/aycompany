@using Microsoft.AspNetCore.Identity
@using MiniMarket.Web.Data
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject ApplicationDbContext _context

@{
    var globalConfig = _context.Configuraciones.FirstOrDefault();
    var logoUrl = globalConfig?.LogoUrl;
    var nombreEmpresa = globalConfig?.NombreEmpresa ?? "MiniMarket Pro";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @nombreEmpresa</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.3.6/css/buttons.bootstrap5.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --brand-primary: #FF6600;
            --brand-primary-hover: #E65C00;
            --brand-secondary: #8BC34A;
            --sidebar-bg: #1e293b;
            --sidebar-hover: rgba(255, 102, 0, 0.1);
        }

        body { 
            background-color: #f8fafc; 
            font-family: 'Outfit', sans-serif; 
            overflow-x: hidden;
        }

        /* --- LOGICA RESPONSIVA DEL SIDEBAR --- */
        #wrapper {
            display: flex;
            width: 100%;
            transition: all 0.3s;
        }

        .sidebar {
            min-width: 250px;
            max-width: 250px;
            background-color: var(--sidebar-bg);
            color: #fff;
            min-height: 100vh;
            transition: margin 0.3s ease-out;
            box-shadow: 2px 0 10px rgba(0,0,0,0.1);
            z-index: 1040;
        }

        .sidebar a { color: #cbd5e1; text-decoration: none; padding: 12px 15px; display: flex; align-items: center; border-radius: 8px; margin-bottom: 5px; margin-left: 10px; margin-right: 10px; transition: all 0.2s; font-weight: 500; }
        .sidebar a:hover { background-color: var(--sidebar-hover); color: var(--brand-primary); }
        .sidebar a.active { background-color: var(--brand-primary); color: #fff;  box-shadow: 0 4px 10px rgba(255, 102, 0, 0.3); }
        .sidebar a.active:hover { color: #fff; }
        .sidebar .section-title { font-size: 0.75rem; text-transform: uppercase; color: #64748b; padding: 10px 20px; font-weight: 700; letter-spacing: 1px; margin-top: 15px; border-bottom: 1px solid rgba(255,255,255,0.05); margin-bottom: 10px; }
        
        .logo-area { padding: 25px 20px; font-size: 1.5rem; font-weight: 700; color: #fff; display: flex; align-items: center; justify-content: center; background-color: rgba(0,0,0,0.15); border-bottom: 1px solid rgba(255,255,255,0.05); }
        .logo-area i { color: var(--brand-primary); }

        .main-content {
            width: 100%;
            padding: 20px;
            transition: all 0.3s;
        }

        .navbar-top { 
            background-color: #fff; 
            box-shadow: 0 4px 15px rgba(0,0,0,.03); 
            padding: 12px 25px; 
            margin-bottom: 25px; 
            border-radius: 12px; 
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* --- REGLAS PARA MÓVILES (Menos de 768px) --- */
        /* AQUÍ ESTABA EL ERROR: Usamos @@media */
        @@media (max-width: 768px) {
            /* Por defecto, en móvil el menú está oculto a la izquierda */
            .sidebar {
                margin-left: -250px; 
            }
            
            /* Cuando activamos la clase .toggled, el menú aparece */
            #wrapper.toggled .sidebar {
                margin-left: 0;
            }
            
            /* Ajustes de padding para móvil */
            .main-content { padding: 10px; }
            .card-body { padding: 1rem; }
        }

        /* Efecto de sombra en tarjetas de layouts generales */
        .card { box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03); border: 1px solid rgba(0,0,0,0.05); border-radius: 12px; }
        .btn-primary { background-color: var(--brand-primary); border-color: var(--brand-primary); }
        .btn-primary:hover, .btn-primary:focus { background-color: var(--brand-primary-hover); border-color: var(--brand-primary-hover); }
        .text-primary { color: var(--brand-primary) !important; }
    </style>
</head>
<body>
    
    <div class="d-flex" id="wrapper">
        
        <div class="sidebar border-end" id="sidebar-wrapper">
            <div class="logo-area mb-3 text-center">
                @if (!string.IsNullOrEmpty(logoUrl))
                {
                    <img src="@logoUrl" alt="Logo Empresa" style="max-height: 50px; max-width: 90%; object-fit: contain;" />
                }
                else
                {
                    <span><i class="fas fa-shopping-basket me-2"></i> @nombreEmpresa</span>
                }
            </div>

            <div class="list-group list-group-flush px-2">
                @if (SignInManager.IsSignedIn(User))
                {
                    <div class="section-title">Principal</div>
                    <a asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                        <i class="fas fa-tachometer-alt me-2" style="width:20px"></i> Dashboard
                    </a>
                    <a asp-controller="Caja" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Caja" ? "active" : "")">
                        <i class="fas fa-cash-register me-2" style="width:20px"></i> Caja / Turno
                    </a>
                    <a asp-controller="Ventas" asp-action="Create" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Ventas" && ViewContext.RouteData.Values["Action"]?.ToString() == "Create" ? "active" : "") text-warning fw-bold">
                        <i class="fas fa-shopping-cart me-2" style="width:20px"></i> PUNTO DE VENTA
                    </a>

                    @if (User.IsInRole("Administrador"))
                    {
                        <div class="section-title text-success">Ventas y Clientes</div>
                        <a asp-controller="Ventas" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Ventas" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                            <i class="fas fa-history me-2" style="width:20px"></i> Historial Ventas
                        </a>
                        <a asp-controller="Gastos" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Gastos" ? "active" : "")">
                            <i class="fas fa-hand-holding-usd me-2" style="width:20px"></i> Control de Gastos
                        </a>
                        <a asp-controller="Caja" asp-action="Historial" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Caja" && ViewContext.RouteData.Values["Action"]?.ToString() == "Historial" ? "active" : "")">
                            <i class="fas fa-cash-register me-2" style="width:20px"></i> Historial Caja
                        </a>
                        <a asp-controller="Clientes" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Clientes" ? "active" : "")">
                            <i class="fas fa-users me-2" style="width:20px"></i> Clientes
                        </a>

                        <div class="section-title text-primary">Compras e Inventario</div>
                        <a asp-controller="Compras" asp-action="Create" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Compras" && ViewContext.RouteData.Values["Action"]?.ToString() == "Create" ? "active" : "")">
                            <i class="fas fa-truck-loading me-2" style="width:20px"></i> Ingreso Mercadería
                        </a>
                        <a asp-controller="Compras" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Compras" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                            <i class="fas fa-file-invoice-dollar me-2" style="width:20px"></i> Historial Compras
                        </a>
                        <a asp-controller="Productos" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Productos" ? "active" : "")">
                            <i class="fas fa-boxes me-2" style="width:20px"></i> Productos
                        </a>
                        <a asp-controller="Etiquetas" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Etiquetas" ? "active" : "")">
                            <i class="fas fa-barcode me-2" style="width:20px"></i> Imprimir Etiquetas
                        </a>
                        <a asp-controller="Categorias" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categorias" ? "active" : "")">
                            <i class="fas fa-tags me-2" style="width:20px"></i> Categorías
                        </a>
                        <a asp-controller="Kardex" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Kardex" ? "active" : "")">
                            <i class="fas fa-exchange-alt me-2" style="width:20px"></i> Kardex
                        </a>
                        <a asp-controller="Proveedores" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Proveedores" ? "active" : "")">
                            <i class="fas fa-truck me-2" style="width:20px"></i> Proveedores
                        </a>

                        <div class="section-title text-danger">Mantenimiento</div>
                        <a asp-controller="Usuarios" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Usuarios" ? "active" : "")">
                            <i class="fas fa-user-shield me-2" style="width:20px"></i> Usuarios
                        </a>
                        <a asp-controller="Configuracion" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Configuracion" ? "active" : "")">
                            <i class="fas fa-cogs me-2" style="width:20px"></i> Configuración
                        </a>
                        <a asp-controller="Seguridad" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Seguridad" ? "active" : "")">
                            <i class="fas fa-shield-alt me-2" style="width:20px"></i> Respaldos y Seguridad
                        </a>
                    }
                }
            </div>
        </div>

        <div class="main-content">
            <div class="navbar-top">
                <button class="btn btn-light shadow-sm text-dark" id="menu-toggle">
                    <i class="fas fa-bars"></i>
                </button>
                
                @if (SignInManager.IsSignedIn(User))
                {
                    <div class="dropdown">
                        <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle text-dark" id="userMenu" data-bs-toggle="dropdown">
                            <i class="fas fa-user-circle fa-2x me-2" style="color: var(--brand-primary);"></i>
                            <div class="d-none d-md-block line-height-normal">
                                <div class="fw-bold">@User.Identity.Name</div>
                                @if (User.IsInRole("Administrador")) { <small class="fw-bold" style="font-size:0.7em; color: var(--brand-primary);">ADMINISTRADOR</small> }
                                else { <small class="text-success fw-bold" style="font-size:0.7em">CAJERO</small> }
                            </div>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 animated fadeIn">
                            <li>
                                <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                    <button type="submit" class="dropdown-item text-danger"><i class="fas fa-sign-out-alt me-2"></i> Cerrar Sesión</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                     <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Login">Iniciar Sesión</a>
                }
            </div>

            <div class="container-fluid p-0">
                @RenderBody()
            </div>
            
            <footer class="mt-5 text-center text-muted small py-3">
                &copy; 2025 - MiniMarket Web - Sistema Profesional
            </footer>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <!-- DataTables Buttons y Exportación -->
    <script src="https://cdn.datatables.net/buttons/2.3.6/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.3.6/js/buttons.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.3.6/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.3.6/js/buttons.print.min.js"></script>
    
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    
    <script>
        $(document).ready(function() {
            $("#menu-toggle").click(function(e) {
                e.preventDefault();
                $("#wrapper").toggleClass("toggled");
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>