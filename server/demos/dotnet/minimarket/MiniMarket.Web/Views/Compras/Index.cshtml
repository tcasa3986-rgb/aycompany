@model IEnumerable<MiniMarket.Web.Models.Compra>

@{
    ViewData["Title"] = "Historial de Compras";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-primary"><i class="fas fa-history me-2"></i>Historial de Compras</h2>
        <p class="text-muted">Registro de ingresos de mercadería al almacén.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
        <i class="fas fa-plus-circle me-2"></i> NUEVA COMPRA
    </a>
</div>

<div class="card shadow border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle" id="tablaCompras">
                <thead class="bg-light">
                    <tr>
                        <th>N° Documento</th>
                        <th>Proveedor</th>
                        <th>Responsable</th>
                        <th>Fecha</th>
                        <th class="text-end">Total</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark">
                                <i class="fas fa-file-invoice text-muted me-2"></i>@item.NumeroDocumento
                            </td>
                            <td>
                                @if (item.Proveedor != null)
                                {
                                    <span class="text-dark fw-bold">@item.Proveedor.RazonSocial</span>
                                }
                                else
                                {
                                    <span class="text-danger">Proveedor Eliminado</span>
                                }
                            </td>
                            <td>
                                <small class="text-muted">@(item.Usuario != null ? item.Usuario.UserName : "Sistema")</small>
                            </td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end fw-bold text-success">
                                S/. @item.Total.ToString("N2")
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Ver Detalles">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // --- CORRECCIÓN AQUÍ: EVITAR ERROR DE REINICIALIZACIÓN ---
            if ($.fn.DataTable.isDataTable('#tablaCompras')) {
                $('#tablaCompras').DataTable().destroy();
            }

            $('#tablaCompras').DataTable({
                dom: '<"row"<"col-sm-12 col-md-4"B><"col-sm-12 col-md-4"l><"col-sm-12 col-md-4"f>>rtip',
                buttons: [
                    { extend: 'excelHtml5', text: '<i class="fas fa-file-excel"></i> Excel', className: 'btn btn-success btn-sm' },
                    { extend: 'pdfHtml5', text: '<i class="fas fa-file-pdf"></i> PDF', className: 'btn btn-danger btn-sm' }
                ],
                "order": [[ 3, "desc" ]], // Ordenar por Fecha (Columna 3) descendente
                language: { url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json' }
            });
        });
    </script>
}