@model IEnumerable<MiniMarket.Web.Models.Categoria>

@{
    ViewData["Title"] = "Categorías";
}

<div class="container-fluid">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-tags me-2"></i>Gestión de Categorías</h5>
            <a asp-action="Create" class="btn btn-light btn-sm text-primary fw-bold">
                <i class="fas fa-plus-circle"></i> Nueva Categoría
            </a>
        </div>
        <div class="card-body">
            @if (Model.Count() > 0)
            {
                <table class="table table-striped table-hover align-middle w-100">
                    <thead class="table-light">
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.Nombre)</th>
                            <th>@Html.DisplayNameFor(model => model.Descripcion)</th>
                            <th>@Html.DisplayNameFor(model => model.Estado)</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="@(item.Estado ? "" : "text-muted")">
                                <td class="fw-bold">@Html.DisplayFor(modelItem => item.Nombre)</td>
                                <td>@Html.DisplayFor(modelItem => item.Descripcion)</td>
                                <td>
                                    @if (item.Estado)
                                    {
                                        <span class="badge bg-success rounded-pill"><i class="fas fa-check me-1"></i>Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger rounded-pill"><i class="fas fa-ban me-1"></i>Inactivo</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm" title="Editar">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        
                                        @if (item.Estado)
                                        {
                                            <a asp-action="CambiarEstado" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" title="Desactivar"
                                               onclick="return confirm('¿Desactivar categoría?');">
                                                <i class="fas fa-power-off"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-action="CambiarEstado" asp-route-id="@item.Id" class="btn btn-outline-success btn-sm" title="Activar">
                                                <i class="fas fa-check-circle"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle fa-2x mb-3"></i>
                    <p>No hay categorías registradas.</p>
                </div>
            }
        </div>
    </div>
</div>