@model IEnumerable<MiniMarket.Web.Models.Cliente>
@{ ViewData["Title"] = "Clientes"; }

<div class="container-fluid">
    <div class="card shadow border-0">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="fas fa-users me-2"></i>Cartera de Clientes</h5>
            <a asp-action="Create" class="btn btn-light btn-sm text-info fw-bold"><i class="fas fa-user-plus"></i> Nuevo Cliente</a>
        </div>
        <div class="card-body">
            @if (Model.Count() > 0) {
                <table class="table table-striped table-hover w-100">
                    <thead class="table-light">
                        <tr>
                            <th>Documento</th>
                            <th>Nombre</th>
                            <th>Teléfono</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr class="@(item.Estado ? "" : "text-muted")">
                                <td class="fw-bold">@item.Documento</td>
                                <td>@item.Nombre</td>
                                <td>@item.Telefono</td>
                                <td>
                                    @if(item.Estado) { <span class="badge bg-success">Activo</span> }
                                    else { <span class="badge bg-secondary">Inactivo</span> }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Compras" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm" title="Historial Compras"><i class="fas fa-shopping-bag"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm ms-1"><i class="fas fa-pen"></i></a>
                                    @if (item.Estado) {
                                        <a asp-action="CambiarEstado" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm ms-1" onclick="return confirm('¿Desactivar?');"><i class="fas fa-power-off"></i></a>
                                    } else {
                                        <a asp-action="CambiarEstado" asp-route-id="@item.Id" class="btn btn-outline-success btn-sm ms-1"><i class="fas fa-check"></i></a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            } else {
                <div class="alert alert-info text-center">No hay clientes registrados.</div>
            }
        </div>
    </div>
</div>