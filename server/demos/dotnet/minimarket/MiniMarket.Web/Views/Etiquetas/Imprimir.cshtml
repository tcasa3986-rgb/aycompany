@model List<MiniMarket.Web.Models.ViewModels.EtiquetaItemViewModel>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Impresión de Etiquetas</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background: #fff;
        }

        .etiqueta-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-start;
            padding: 10px;
        }

        .etiqueta {
            width: 50mm;
            height: 30mm;
            margin: 2mm;
            border: 1px dashed #ccc;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            box-sizing: border-box;
            background-color: white;
            page-break-inside: avoid;
            text-align: center;
            padding: 2mm;
        }

        .nombre-producto {
            font-size: 8px;
            font-weight: bold;
            margin-bottom: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            width: 100%;
        }

        .precio-producto {
            font-size: 11px;
            font-weight: bold;
            margin-top: 1px;
        }

        .barcode-svg {
            max-width: 100%;
            height: 18mm;
        }

        @@page {
            margin: 5mm;
            size: auto;
        }

        @@media print {
            .etiqueta {
                border: none; /* No imprimir borde punteado */
            }
            body {
                -webkit-print-color-adjust: exact;
            }
        }
    </style>
</head>
<body>
    <div class="etiqueta-container">
        @if(Model != null)
        {
            foreach (var item in Model)
            {
                for (int i = 0; i < item.Cantidad; i++)
                {
                    <div class="etiqueta">
                        <div class="nombre-producto">@item.Nombre.ToUpper()</div>
                        <svg class="barcode-svg"
                             jsbarcode-value="@item.Codigo"
                             jsbarcode-textmargin="0"
                             jsbarcode-height="30"
                             jsbarcode-width="1.5"
                             jsbarcode-displayvalue="true"
                             jsbarcode-fontsize="12"
                             jsbarcode-fontoptions="bold">
                        </svg>
                        <div class="precio-producto">S/. @item.Precio.ToString("N2")</div>
                    </div>
                }
            }
        }
    </div>

    <!-- JsBarcode CDN -->
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.0/dist/JsBarcode.all.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Inicializar todos los códigos de barras
            JsBarcode(".barcode-svg").init();

            // Lanzar menú de impresión automáticamente
            setTimeout(function() {
                window.print();
            }, 500);
        });
    </script>
</body>
</html>
