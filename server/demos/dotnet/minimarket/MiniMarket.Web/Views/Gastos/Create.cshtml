@model MiniMarket.Web.Models.Gasto

@{
    ViewData["Title"] = "Registrar Gasto";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5 col-xl-4 align-self-center mt-5">
        <div class="card shadow-lg border-0" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header bg-danger text-white text-center py-4 border-0">
                <i class="fas fa-hand-holding-usd fa-3x mb-2"></i>
                <h4 class="mb-0 fw-bold">Registrar Gasto Operativo</h4>
                <small class="text-white-50">El monto será deducido de su caja actual</small>
            </div>
            <div class="card-body p-4 bg-white">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Concepto" class="form-label fw-bold text-muted small">MOTIVO / CONCEPTO:</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="fas fa-file-signature text-secondary"></i></span>
                            <input asp-for="Concepto" class="form-control" placeholder="Ej. Pago de Almuerzo, Viáticos, Útiles..." autocomplete="off" required />
                        </div>
                        <span asp-validation-for="Concepto" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Monto" class="form-label fw-bold text-muted small">MONTO EXTRAÍDO:</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-light fw-bold text-danger">S/.</span>
                            <input asp-for="Monto" class="form-control text-end fw-bold text-danger" type="number" step="0.50" min="0" placeholder="0.00" required />
                        </div>
                        <span asp-validation-for="Monto" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-danger btn-lg shadow-sm">
                            <i class="fas fa-check-circle me-2"></i> REGISTRAR SALIDA
                        </button>
                    </div>
                </form>
            </div>
            <div class="card-footer text-center bg-light border-0 py-3">
                <a asp-controller="Caja" asp-action="Index" class="text-decoration-none text-muted fw-bold">
                    <i class="fas fa-arrow-left me-1"></i> Volver a Mi Caja
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
