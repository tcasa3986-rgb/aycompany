@model IEnumerable<MiniMarket.Web.Models.MovimientoInventario>

@{
    ViewData["Title"] = "Kardex de Movimientos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-primary"><i class="fas fa-exchange-alt me-2"></i>Kardex de Movimientos</h2>
        <p class="text-muted">Consulta el historial de entradas y salidas por producto.</p>
    </div>
    @if (User.IsInRole("Administrador"))
    {
        <a asp-action="Ajuste" class="btn btn-warning shadow-sm">
            <i class="fas fa-sliders-h me-2"></i>Ajuste Manual
        </a>
    }
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow border-0 mb-4">
    <div class="card-body bg-light">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-bold">Producto:</label>
                <select name="productoId" class="form-select select2" onchange="this.form.submit()">
                    <option value="">-- Seleccione un producto --</option>
                    @foreach (var item in (SelectList)ViewBag.Productos)
                    {
                        if (ViewBag.ProductoSeleccionado?.ToString() == item.Value)
                        {
                            <option value="@item.Value" selected>@item.Text</option>
                        }
                        else
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold">Desde:</label>
                <input type="date" name="desde" class="form-control" value="@ViewBag.Desde" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold">Hasta:</label>
                <input type="date" name="hasta" class="form-control" value="@ViewBag.Hasta" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search me-1"></i>Filtrar</button>
            </div>
            <div class="col-md-1">
                <a asp-action="Index" class="btn btn-outline-secondary w-100" title="Limpiar filtros"><i class="fas fa-times"></i></a>
            </div>
        </form>
    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="card shadow border-0">
        <div class="card-body">
            <table class="table table-striped table-hover w-100" id="tablaKardex">
                <thead class="table-dark">
                    <tr>
                        <th>Fecha y Hora</th>
                        <th>Tipo</th>
                        <th>Referencia</th>
                        <th>Motivo</th>
                        <th class="text-center">Cantidad</th>
                        <th>Usuario</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var esEntrada = item.TipoMovimiento == "ENTRADA" || item.TipoMovimiento == "AJUSTE-ENTRADA";
                        var badgeColor = esEntrada ? "success" : item.TipoMovimiento == "AJUSTE" ? "warning text-dark" : "danger";
                        var icono = esEntrada ? "fa-arrow-down" : item.TipoMovimiento == "AJUSTE" ? "fa-sliders-h" : "fa-arrow-up";
                        <tr>
                            <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm:ss")</td>
                            <td>
                                <span class="badge bg-@badgeColor">
                                    <i class="fas @icono me-1"></i>@item.TipoMovimiento
                                </span>
                            </td>
                            <td class="fw-bold">@item.Referencia</td>
                            <td class="text-muted small">@item.Motivo</td>
                            <td class="text-center fw-bold fs-5">
                                @if (esEntrada)
                                {
                                    <span class="text-success">+@item.Cantidad</span>
                                }
                                else
                                {
                                    <span class="text-danger">-@item.Cantidad</span>
                                }
                            </td>
                            <td class="text-muted small">@item.Usuario</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else if (ViewBag.ProductoSeleccionado != null)
{
    <div class="alert alert-warning text-center">
        <i class="fas fa-inbox fa-2x d-block mb-2"></i>
        Este producto no tiene movimientos registrados en el período seleccionado.
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.select2').select2({ theme: 'bootstrap-5', width: '100%', placeholder: "Buscar producto..." });
            if ($('#tablaKardex').length) {
                $('#tablaKardex').DataTable({
                    "order": [[ 0, "desc" ]],
                    language: { url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json' }
                });
            }
        });
    </script>
}