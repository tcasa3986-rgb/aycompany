@model MiniMarket.Web.Models.AperturaCaja
@{ ViewData["Title"] = "Cerrar Caja"; }

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white text-center py-3">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-file-invoice-dollar me-2"></i>Arqueo de Caja</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-light border text-center mb-4">
                        <div class="row">
                            <div class="col-6 border-end">
                                <small class="text-muted">Monto Inicial</small>
                                <h5 class="fw-bold">S/. @Model.MontoInicial.ToString("N2")</h5>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">Ventas del Turno</small>
                                <h5 class="fw-bold text-success">+ S/. @ViewBag.VentasSistema.ToString("N2")</h5>
                            </div>
                        </div>
                        <hr>
                        <h6 class="text-muted mb-1">Debería haber en caja:</h6>
                        <h2 class="fw-bold text-dark">S/. @ViewBag.TotalEsperado.ToString("N2")</h2>
                    </div>

                    <form asp-action="Cerrar" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold">Dinero contado en efectivo (Real):</label>
                            <input name="montoReal" type="number" step="0.01" class="form-control form-control-lg text-center fw-bold border-danger" required />
                            <small class="text-muted">Ingresa la suma total de billetes y monedas que tienes físicamente.</small>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold">CONFIRMAR CIERRE</button>
                            <a asp-action="Index" class="btn btn-light">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>