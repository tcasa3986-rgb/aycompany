@page
@model MiniMarket.Web.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - MiniMarket Pro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand-primary: #FF6600; /* Vibrant Orange */
            --brand-primary-hover: #E65C00;
            --brand-secondary: #8BC34A; /* Fresh Green */
            --bg-light: #F8FAFC;
        }

        body {
            font-family: 'Outfit', sans-serif;
            margin: 0;
            padding: 0;
            height: 100vh;
            background-color: var(--bg-light);
            display: flex;
            overflow: hidden;
        }

        .login-layout {
            display: flex;
            width: 100%;
            height: 100%;
        }

        .login-image-section {
            flex: 1;
            display: none;
            background-image: url('/images/minimarket_bg.png');
            background-size: cover;
            background-position: center;
            position: relative;
        }

        .login-image-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(0,0,0,0.5) 0%, rgba(255, 102, 0, 0.3) 100%);
        }

        .login-image-content {
            position: absolute;
            bottom: 12%;
            left: 10%;
            color: white;
            max-width: 80%;
            z-index: 1;
        }

        .login-image-content h1 {
            font-weight: 700;
            font-size: 3.5rem;
            margin-bottom: 1rem;
            text-shadow: 0 4px 10px rgba(0,0,0,0.5);
            line-height: 1.1;
            letter-spacing: -1px;
        }

        .login-image-content p {
            font-size: 1.25rem;
            font-weight: 300;
            opacity: 0.9;
            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
            max-width: 600px;
        }

        @@media (min-width: 992px) {
            .login-image-section {
                display: block;
            }
        }

        .login-form-section {
            flex: 0 0 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #ffffff;
            padding: 2rem;
            box-shadow: -15px 0 30px rgba(0,0,0,0.05);
            z-index: 2;
        }

        @@media (min-width: 992px) {
            .login-form-section {
                flex: 0 0 450px;
            }
        }
        
        @@media (min-width: 1200px) {
            .login-form-section {
                flex: 0 0 500px;
            }
        }

        .login-card {
            width: 100%;
            max-width: 400px;
            margin: 0 auto;
        }

        .brand-icon-wrapper {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 80px;
            height: 80px;
            border-radius: 20px;
            background: rgba(255, 102, 0, 0.1);
            margin-bottom: 1.5rem;
        }

        .brand-icon {
            color: var(--brand-primary);
            font-size: 2.5rem;
        }

        .brand-title {
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 0.5rem;
            font-size: 2rem;
            letter-spacing: -0.5px;
        }

        .brand-subtitle {
            color: #64748b;
            margin-bottom: 2.5rem;
            font-size: 1rem;
            font-weight: 400;
        }

        .form-floating .form-control {
            border-radius: 12px;
            border: 1.5px solid #e2e8f0;
            padding: 1rem 1rem;
            height: calc(3.5rem + 2px);
            font-size: 1rem;
            transition: all 0.2s ease;
        }

        .form-floating .form-control:focus {
            border-color: var(--brand-primary);
            box-shadow: 0 0 0 0.25rem rgba(255, 102, 0, 0.15);
        }
        
        .form-floating label {
            color: #94a3b8;
            padding-left: 1.25rem;
        }

        .form-floating .form-control:focus ~ label,
        .form-floating .form-control:not(:placeholder-shown) ~ label {
            color: var(--brand-primary);
            transform: scale(0.85) translateY(-1rem) translateX(0.15rem);
            background-color: transparent;
        }

        .btn-primary {
            background-color: var(--brand-primary);
            border-color: var(--brand-primary);
            padding: 0.875rem;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1.1rem;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-top: 1rem;
        }

        .btn-primary:hover, .btn-primary:focus {
            background-color: var(--brand-primary-hover);
            border-color: var(--brand-primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(255, 102, 0, 0.3);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .footer-text {
            color: #94a3b8;
            font-size: 0.85rem;
            margin-top: 3.5rem;
            text-align: center;
        }
        
        .text-danger {
            font-weight: 500;
            margin-top: 0.25rem;
            display: block;
            margin-left: 0.5rem;
        }
    </style>
</head>
<body>

    <div class="login-layout">
        <!-- Image Section -->
        <div class="login-image-section">
            <div class="login-image-content">
                <h1>Frescura y Rapidez<br>en cada venta.</h1>
                <p>Gestiona tu minimarket con la plataforma más intuitiva y eficiente. Lleva el control de tu inventario, ventas y ganancias con facilidad.</p>
            </div>
        </div>

        <!-- Form Section -->
        <div class="login-form-section">
            <div class="login-card">
                <div class="text-center mb-4">
                    <div class="brand-icon-wrapper">
                        <i class="fas fa-shopping-basket brand-icon"></i>
                    </div>
                    <h2 class="brand-title">MiniMarket Pro</h2>
                    <p class="brand-subtitle">Bienvenido de vuelta, ingresa tus datos</p>
                </div>
                
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" placeholder="nombre@ejemplo.com" />
                        <label asp-for="Input.Email">Correo Electrónico</label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.Password" class="form-control" placeholder="Contraseña" />
                        <label asp-for="Input.Password">Contraseña</label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mb-4">
                        <button type="submit" class="btn btn-primary w-100">
                            INGRESAR AL SISTEMA <i class="fas fa-arrow-right"></i>
                        </button>
                    </div>
                </form>

                <div class="footer-text">
                    &copy; 2025 Sistema MiniMarket.<br>Todos los derechos reservados.
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>