@*
  Mini bar chart simple en SVG para mostrar tendencia.
*@
@if (Datos != null && Datos.Any())
{
    <div class="bar-chart">
        <svg viewBox="0 0 @(Datos.Count * 60) 200" width="100%" height="180" preserveAspectRatio="none">
            @{
                var max = Datos.Max(d => d.Valor);
                if (max == 0) max = 1;
                int x = 10;
            }
            @foreach (var d in Datos)
            {
                var h = (double)(d.Valor / max) * 160;
                var y = 180 - h;
                <g>
                    <rect x="@x" y="@y" width="40" height="@h" fill="#1F2C50" rx="4" />
                    <rect x="@x" y="@y" width="40" height="6" fill="#F4A93C" rx="3" />
                    <text x="@(x + 20)" y="195" font-size="10" text-anchor="middle" fill="#5D6B82">@d.Etiqueta</text>
                </g>
                x += 60;
            }
        </svg>
    </div>
}

@code {
    [Parameter] public List<TendenciaItemDto>? Datos { get; set; }
}
