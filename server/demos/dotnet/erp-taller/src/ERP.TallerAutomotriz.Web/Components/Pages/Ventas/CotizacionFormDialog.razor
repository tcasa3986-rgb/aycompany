@inject ISalesService SalesSvc
@inject AuthenticationStateProvider AuthState

<MudDialog>
    <DialogContent>
        <MudForm @ref="form">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudAutocomplete T="ClienteListDto" @bind-Value="clienteSel"
                                     Label="Cliente *" Required="true"
                                     SearchFunc="@BuscarClientes"
                                     ToStringFunc="@(c => c == null ? "" : $"{c.Codigo} — {c.NombreRazonSocial}")"
                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                     ResetValueOnEmptyText="false" CoerceText="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="fecha" Label="Fecha *" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="validaHasta" Label="Válida hasta *" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12">
                    <div class="d-flex align-center justify-space-between mb-2">
                        <MudText Typo="Typo.subtitle2" Class="fw-bold">Items</MudText>
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="AgregarItem">Agregar item</MudButton>
                    </div>
                    @foreach (var item in items)
                    {
                        <MudPaper Class="pa-2 mb-2" Elevation="0" Style="background:#F8FAFD;border-radius:8px;">
                            <MudGrid Spacing="1">
                                <MudItem xs="12" sm="5">
                                    <MudTextField @bind-Value="item.Descripcion" Label="Descripción" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6" sm="2">
                                    <MudNumericField @bind-Value="item.Cantidad" Label="Cant." Min="0" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6" sm="3">
                                    <MudNumericField @bind-Value="item.PrecioUnitario" Label="P. Unit." Min="0" Format="N2" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" sm="2" Class="d-flex align-center justify-center">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                   OnClick="() => items.Remove(item)" />
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    }
                </MudItem>

                <MudItem xs="12">
                    <MudPaper Class="pa-3 text-right" Elevation="0" Style="background:#F4F6FA;border-radius:8px;">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Subtotal: S/. @Subtotal.ToString("N2")</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">IGV (18%): S/. @Impuesto.ToString("N2")</MudText>
                        <MudText Typo="Typo.h6" Class="fw-bold mt-1">Total: S/. @Total.ToString("N2")</MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Cotizacion.Observaciones" Label="Observaciones" Lines="2"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>

            @if (!string.IsNullOrEmpty(error))
            {
                <MudAlert Severity="Severity.Error" Class="mt-3">@error</MudAlert>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Guardar" Disabled="@guardando"
                   StartIcon="@Icons.Material.Filled.Save">@(guardando ? "Guardando..." : "Guardar")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public CotizacionFormDto Cotizacion { get; set; } = new();
    [Parameter] public List<ClienteListDto> Clientes { get; set; } = new();

    private MudForm? form;
    private bool guardando;
    private string? error;
    private ClienteListDto? clienteSel;
    private DateTime? fecha = DateTime.Today;
    private DateTime? validaHasta = DateTime.Today.AddDays(15);
    private List<FacturaItemFormDto> items = new();

    protected override void OnInitialized()
    {
        if (Cotizacion.Items.Any()) items = Cotizacion.Items;
        else items.Add(new FacturaItemFormDto());
    }

    private decimal Subtotal => items.Sum(i => i.Cantidad * i.PrecioUnitario);
    private decimal Impuesto => Subtotal * 0.18m;
    private decimal Total => Subtotal + Impuesto;

    private void AgregarItem() => items.Add(new FacturaItemFormDto());

    private Task<IEnumerable<ClienteListDto>> BuscarClientes(string? value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(Clientes.Take(15).AsEnumerable());
        var v = value.ToLower();
        return Task.FromResult(Clientes.Where(c =>
            c.NombreRazonSocial.ToLower().Contains(v) ||
            c.Codigo.ToLower().Contains(v) ||
            c.DocumentoIdentidad.Contains(v)).Take(15).AsEnumerable());
    }

    private async Task Guardar()
    {
        if (clienteSel == null) { error = "Selecciona un cliente."; return; }
        if (!items.Any(i => !string.IsNullOrWhiteSpace(i.Descripcion))) { error = "Agrega al menos un item."; return; }

        Cotizacion.ClienteId = clienteSel.Id;
        if (fecha.HasValue) Cotizacion.Fecha = fecha.Value;
        if (validaHasta.HasValue) Cotizacion.ValidaHasta = validaHasta.Value;
        Cotizacion.Items = items.Where(i => !string.IsNullOrWhiteSpace(i.Descripcion)).ToList();

        guardando = true; error = null;
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            await SalesSvc.CrearCotizacionAsync(Cotizacion, auth.User.Identity?.Name);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { error = ex.Message; }
        finally { guardando = false; }
    }

    private void Cancelar() => MudDialog.Cancel();
}
