@inject IPersonnelService PersonnelSvc

<MudDialog>
    <DialogContent>
        <MudForm @ref="form">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudSelect T="int" @bind-Value="Comision.TecnicoId" Label="Técnico *" Required="true"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var t in Tecnicos)
                        {
                            <MudSelectItem Value="t.Id">@t.NombreCompleto · @t.PorcentajeComision%</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="fecha" Label="Fecha *"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="numeroOT" Label="ID de OT (opcional)" Min="0"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="Comision.MontoBase" Label="Monto base (S/.) *" Required="true"
                                     Min="0" Variant="Variant.Outlined" Margin="Margin.Dense" Format="N2" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="Comision.Porcentaje" Label="% comisión *" Required="true"
                                     Min="0" Max="100" Variant="Variant.Outlined" Margin="Margin.Dense" Format="N2" />
                </MudItem>
                <MudItem xs="12">
                    <MudPaper Class="pa-3 text-center" Elevation="0" Style="background:#F4F6FA;border-radius:8px;">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">COMISIÓN A REGISTRAR</MudText>
                        <MudText Typo="Typo.h5" Class="fw-bold" Color="Color.Primary">
                            S/. @((Comision.MontoBase * Comision.Porcentaje / 100).ToString("N2"))
                        </MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            @if (!string.IsNullOrEmpty(error))
            {
                <MudAlert Severity="Severity.Error" Class="mt-3">@error</MudAlert>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Guardar" Disabled="@guardando"
                   StartIcon="@Icons.Material.Filled.Save">@(guardando ? "Guardando..." : "Registrar")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ComisionFormDto Comision { get; set; } = new();
    [Parameter] public List<TecnicoFullDto> Tecnicos { get; set; } = new();

    private MudForm? form;
    private bool guardando;
    private string? error;
    private DateTime? fecha = DateTime.Today;
    private int? numeroOT;

    private async Task Guardar()
    {
        if (form == null) return;
        await form.Validate();
        if (!form.IsValid) return;
        if (fecha.HasValue) Comision.Fecha = fecha.Value;
        if (numeroOT.HasValue && numeroOT.Value > 0) Comision.OrdenTrabajoId = numeroOT.Value;

        guardando = true; error = null;
        try
        {
            await PersonnelSvc.RegistrarComisionAsync(Comision);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { error = ex.Message; }
        finally { guardando = false; }
    }

    private void Cancelar() => MudDialog.Cancel();
}
