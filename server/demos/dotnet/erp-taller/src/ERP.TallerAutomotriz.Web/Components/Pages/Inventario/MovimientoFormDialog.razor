@inject IInventoryService InventorySvc
@inject AuthenticationStateProvider AuthState

<MudDialog>
    <DialogContent>
        <MudForm @ref="form">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudSelect T="int" @bind-Value="Movimiento.RepuestoId" Label="Repuesto *"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var r in Repuestos)
                        {
                            <MudSelectItem Value="@r.Id">@r.CodigoInterno — @r.Descripcion</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect T="int" @bind-Value="Movimiento.AlmacenId" Label="Almacén *"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var a in Almacenes)
                        {
                            <MudSelectItem Value="@a.Id">@a.Nombre</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="TipoMovimientoInventario" @bind-Value="Movimiento.Tipo" Label="Tipo *"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="TipoMovimientoInventario.EntradaCompra">Entrada por compra</MudSelectItem>
                        <MudSelectItem Value="TipoMovimientoInventario.DevolucionCliente">Devolución de cliente</MudSelectItem>
                        <MudSelectItem Value="TipoMovimientoInventario.AjustePositivo">Ajuste positivo (+)</MudSelectItem>
                        <MudSelectItem Value="TipoMovimientoInventario.AjusteNegativo">Ajuste negativo (-)</MudSelectItem>
                        <MudSelectItem Value="TipoMovimientoInventario.SalidaConsumoOT">Salida (consumo OT)</MudSelectItem>
                        <MudSelectItem Value="TipoMovimientoInventario.DevolucionProveedor">Devolución a proveedor</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="Movimiento.Cantidad" Label="Cantidad *" Required="true"
                                     Min="0.0001m" Variant="Variant.Outlined" Margin="Margin.Dense" Format="N4" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="Movimiento.CostoUnitario" Label="Costo unitario (S/.)"
                                     Min="0" Variant="Variant.Outlined" Margin="Margin.Dense" Format="N2" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Movimiento.NumeroDocumento" Label="N° documento (OC/Fact./OT)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Movimiento.TipoDocumento" Label="Tipo de documento"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Movimiento.Justificacion" Label="Justificación / Observaciones"
                                  Lines="2" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>

            @if (!string.IsNullOrEmpty(error))
            {
                <MudAlert Severity="Severity.Error" Class="mt-3">@error</MudAlert>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Guardar" Disabled="@guardando"
                   StartIcon="@Icons.Material.Filled.SwapHoriz">@(guardando ? "Procesando..." : "Registrar")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public MovimientoFormDto Movimiento { get; set; } = new();
    [Parameter] public List<(int Id, string CodigoInterno, string Descripcion)> Repuestos { get; set; } = new();
    [Parameter] public List<AlmacenDto> Almacenes { get; set; } = new();

    private MudForm? form;
    private bool guardando;
    private string? error;

    private async Task Guardar()
    {
        if (form == null) return;
        await form.Validate();
        if (!form.IsValid) return;

        guardando = true;
        error = null;
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var usuario = auth.User.Identity?.Name;
            await InventorySvc.RegistrarMovimientoAsync(Movimiento, usuario);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

    private void Cancelar() => MudDialog.Cancel();
}
