@inject IWorkshopService WorkshopSvc
@inject AuthenticationStateProvider AuthState

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">
            OT <strong>@OT.Numero</strong> — @OT.Cliente
        </MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
            Estado actual: <strong>@OT.Estado</strong>
        </MudText>

        <MudSelect T="EstadoOT" @bind-Value="nuevoEstado" Label="Nuevo estado *"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3">
            <MudSelectItem Value="EstadoOT.Recibido">Recibido</MudSelectItem>
            <MudSelectItem Value="EstadoOT.EnDiagnostico">En diagnóstico</MudSelectItem>
            <MudSelectItem Value="EstadoOT.EnReparacion">En reparación</MudSelectItem>
            <MudSelectItem Value="EstadoOT.EnEsperaRepuesto">En espera de repuesto</MudSelectItem>
            <MudSelectItem Value="EstadoOT.ControlCalidad">Control de calidad</MudSelectItem>
            <MudSelectItem Value="EstadoOT.Listo">Listo</MudSelectItem>
            <MudSelectItem Value="EstadoOT.Entregado">Entregado</MudSelectItem>
            <MudSelectItem Value="EstadoOT.Cancelado">Cancelado</MudSelectItem>
        </MudSelect>

        <MudTextField @bind-Value="comentario" Label="Comentario (opcional)" Lines="2"
                      Variant="Variant.Outlined" Margin="Margin.Dense" />

        @if (!string.IsNullOrEmpty(error))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Guardar" Disabled="@guardando"
                   StartIcon="@Icons.Material.Filled.SwapHoriz">@(guardando ? "Cambiando..." : "Cambiar estado")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public OrdenTrabajoListDto OT { get; set; } = default!;

    private EstadoOT nuevoEstado;
    private string? comentario;
    private bool guardando;
    private string? error;

    protected override void OnInitialized()
    {
        nuevoEstado = OT.Estado;
    }

    private async Task Guardar()
    {
        if (nuevoEstado == OT.Estado)
        {
            error = "Selecciona un estado distinto al actual.";
            return;
        }
        guardando = true; error = null;
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var usuario = auth.User.Identity?.Name;
            await WorkshopSvc.CambiarEstadoAsync(new CambioEstadoDto
            {
                OrdenTrabajoId = OT.Id,
                NuevoEstado = nuevoEstado,
                Comentario = comentario
            }, usuario);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { error = ex.Message; }
        finally { guardando = false; }
    }

    private void Cancelar() => MudDialog.Cancel();
}
