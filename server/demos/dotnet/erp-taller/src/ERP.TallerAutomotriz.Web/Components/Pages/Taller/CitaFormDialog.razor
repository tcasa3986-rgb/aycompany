@inject IWorkshopService WorkshopSvc
@inject ICustomerService CustomerSvc
@inject AuthenticationStateProvider AuthState

<MudDialog>
    <DialogContent>
        <MudForm @ref="form">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudAutocomplete T="ClienteListDto" @bind-Value="clienteSeleccionado"
                                     @bind-Value:after="OnClienteCambiado"
                                     Label="Cliente *" Required="true"
                                     SearchFunc="@BuscarClientes"
                                     ToStringFunc="@(c => c == null ? "" : $"{c.Codigo} — {c.NombreRazonSocial}")"
                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                     ResetValueOnEmptyText="false" CoerceText="true"
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" />
                </MudItem>

                <MudItem xs="12">
                    <MudSelect T="int?" @bind-Value="Cita.VehiculoId" Label="Vehículo (opcional)"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                        <MudSelectItem T="int?" Value="null">Sin especificar</MudSelectItem>
                        @foreach (var v in vehiculos)
                        {
                            <MudSelectItem T="int?" Value="v.Id">@v.Placa — @v.Marca @v.Modelo</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="fecha" Label="Fecha *" Required="true"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTimePicker @bind-Time="hora" Label="Hora *" Required="true"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="Cita.DuracionMinutos" Label="Duración (min)" Min="15" Max="480"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="EstadoCita" @bind-Value="Cita.Estado" Label="Estado"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="EstadoCita.Pendiente">Pendiente</MudSelectItem>
                        <MudSelectItem Value="EstadoCita.Confirmada">Confirmada</MudSelectItem>
                        <MudSelectItem Value="EstadoCita.EnEspera">En espera</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" @bind-Value="Cita.ServicioId" Label="Servicio principal"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                        <MudSelectItem T="int?" Value="null">Sin especificar</MudSelectItem>
                        @foreach (var s in Servicios)
                        {
                            <MudSelectItem T="int?" Value="s.Id">@s.Nombre — S/. @s.PrecioEstandar.ToString("N0")</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="int?" @bind-Value="Cita.TecnicoPreferidoId" Label="Técnico preferido"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                        <MudSelectItem T="int?" Value="null">Cualquiera</MudSelectItem>
                        @foreach (var t in Tecnicos)
                        {
                            <MudSelectItem T="int?" Value="t.Id">@t.NombreCompleto</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Cita.Comentarios" Label="Comentarios" Lines="2"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>

            @if (!string.IsNullOrEmpty(error))
            {
                <MudAlert Severity="Severity.Error" Class="mt-3">@error</MudAlert>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Guardar" Disabled="@guardando"
                   StartIcon="@Icons.Material.Filled.Save">@(guardando ? "Guardando..." : "Guardar")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public CitaFormDto Cita { get; set; } = new();
    [Parameter] public List<ClienteListDto> Clientes { get; set; } = new();
    [Parameter] public List<ServicioListDto> Servicios { get; set; } = new();
    [Parameter] public List<TecnicoListDto> Tecnicos { get; set; } = new();

    private MudForm? form;
    private bool guardando;
    private string? error;
    private ClienteListDto? clienteSeleccionado;
    private List<VehiculoListDto> vehiculos = new();
    private DateTime? fecha;
    private TimeSpan? hora;

    protected override async Task OnInitializedAsync()
    {
        fecha = Cita.FechaHora.Date;
        hora = Cita.FechaHora.TimeOfDay;
        if (Cita.ClienteId > 0)
        {
            clienteSeleccionado = Clientes.FirstOrDefault(c => c.Id == Cita.ClienteId);
            if (clienteSeleccionado != null) await CargarVehiculos();
        }
    }

    private Task<IEnumerable<ClienteListDto>> BuscarClientes(string? value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(Clientes.Take(15).AsEnumerable());
        var v = value.ToLower();
        return Task.FromResult(Clientes.Where(c =>
            c.NombreRazonSocial.ToLower().Contains(v) ||
            c.Codigo.ToLower().Contains(v) ||
            c.DocumentoIdentidad.Contains(v)).Take(15).AsEnumerable());
    }

    private async Task OnClienteCambiado()
    {
        if (clienteSeleccionado != null)
        {
            Cita.ClienteId = clienteSeleccionado.Id;
            await CargarVehiculos();
        }
    }

    private async Task CargarVehiculos()
    {
        if (clienteSeleccionado == null) return;
        var resp = await CustomerSvc.ListarVehiculosAsync(null, clienteSeleccionado.Id, 1, 50);
        vehiculos = resp.Items.Where(v => v.Activo).ToList();
    }

    private async Task Guardar()
    {
        if (form == null) return;
        await form.Validate();
        if (!form.IsValid) return;
        if (clienteSeleccionado == null) { error = "Selecciona un cliente."; return; }
        if (!fecha.HasValue || !hora.HasValue) { error = "Selecciona fecha y hora."; return; }

        Cita.ClienteId = clienteSeleccionado.Id;
        Cita.FechaHora = fecha.Value.Date.Add(hora.Value);

        guardando = true; error = null;
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var usuario = auth.User.Identity?.Name;
            if (Cita.Id == 0)
                await WorkshopSvc.CrearCitaAsync(Cita, usuario);
            else
                await WorkshopSvc.ActualizarCitaAsync(Cita, usuario);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { error = ex.Message; }
        finally { guardando = false; }
    }

    private void Cancelar() => MudDialog.Cancel();
}
