@inject ISalesService SalesSvc
@inject AuthenticationStateProvider AuthState

<MudDialog>
    <DialogContent>
        <MudForm @ref="form">
            <MudText Typo="Typo.caption" Color="Color.Secondary">COMPROBANTE</MudText>
            <MudText Typo="Typo.body1" Class="fw-bold mb-2">@Comprobante</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Saldo pendiente: <strong>S/. @SaldoMaximo.ToString("N2")</strong></MudText>

            <MudGrid Spacing="2" Class="mt-3">
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="Pago.Monto" Label="Monto a pagar (S/.) *" Required="true"
                                     Min="0.01m" Max="@SaldoMaximo" Variant="Variant.Outlined" Margin="Margin.Dense" Format="N2" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="FormaPago" @bind-Value="Pago.FormaPago" Label="Forma de pago"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="FormaPago.Efectivo">Efectivo</MudSelectItem>
                        <MudSelectItem Value="FormaPago.TarjetaCredito">Tarjeta de crédito</MudSelectItem>
                        <MudSelectItem Value="FormaPago.TarjetaDebito">Tarjeta de débito</MudSelectItem>
                        <MudSelectItem Value="FormaPago.Transferencia">Transferencia</MudSelectItem>
                        <MudSelectItem Value="FormaPago.PagoQR">Pago QR</MudSelectItem>
                        <MudSelectItem Value="FormaPago.Cheque">Cheque</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Pago.NumeroReferencia" Label="N° referencia / operación"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Pago.Observaciones" Label="Observaciones" Lines="2"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>

            @if (!string.IsNullOrEmpty(error))
            {
                <MudAlert Severity="Severity.Error" Class="mt-3">@error</MudAlert>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="Guardar" Disabled="@guardando"
                   StartIcon="@Icons.Material.Filled.PointOfSale">@(guardando ? "Procesando..." : "Registrar pago")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public PagoFormDto Pago { get; set; } = new();
    [Parameter] public decimal SaldoMaximo { get; set; }
    [Parameter] public string Comprobante { get; set; } = "";

    private MudForm? form;
    private bool guardando;
    private string? error;

    private async Task Guardar()
    {
        if (form == null) return;
        await form.Validate();
        if (!form.IsValid) return;

        guardando = true; error = null;
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            await SalesSvc.RegistrarPagoAsync(Pago, auth.User.Identity?.Name);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { error = ex.Message; }
        finally { guardando = false; }
    }

    private void Cancelar() => MudDialog.Cancel();
}
