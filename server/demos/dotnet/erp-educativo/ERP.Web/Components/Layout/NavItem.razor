@using MudBlazor

<MudNavLink Href="@Href" Match="@(Href == "/" ? NavLinkMatch.All : NavLinkMatch.Prefix)"
            Icon="@Icon"
            Style="@(Indent ? "padding-left:32px; color:rgba(255,255,255,0.85);" : "color:rgba(255,255,255,0.85);")"
            ActiveClass="nav-item-active">
    @Text
</MudNavLink>

@code {
    [Parameter] public string Href { get; set; } = "/";
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string Text { get; set; } = "";
    [Parameter] public bool Indent { get; set; } = false;
}
