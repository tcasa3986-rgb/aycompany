@page "/evaluacion/asistencia"
@using ERP.Application.Features.Evaluacion.Asistencia
@using ERP.Domain.Enums
@using MediatR
@inject IMediator Mediator
@inject ISnackbar Snackbar

<MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-4" Style="font-weight: 700;">Registro de Asistencia</MudText>

<MudPaper Elevation="2" Class="pa-4 mb-4" Style="border-radius:12px;">
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudSelect T="int" Label="Seleccionar Sección" @bind-Value="_seccionSeleccionada" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" SelectedValuesChanged="OnSeccionChanged">
                <MudSelectItem Value="0" Disabled="true">Seleccione una clase...</MudSelectItem>
                @foreach (var sec in _secciones)
                {
                    <MudSelectItem Value="@sec.Id">@($"{sec.CursoNombre} - {sec.Nombre} ({sec.PeriodoNombre})")</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudDatePicker Label="Fecha de la Clase" @bind-Date="_fechaSeleccionada" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Today" />
        </MudItem>
        <MudItem xs="12" md="2" Class="d-flex align-center">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CargarAlumnos" Disabled="@(_seccionSeleccionada == 0 || _fechaSeleccionada == null || _cargando)" FullWidth>
                @if (_cargando) { <MudProgressCircular Class="ms-n1" Size="MudBlazor.Size.Small" Indeterminate="true" /> }
                else { <MudText>Cargar</MudText> }
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_alumnos != null)
{
    <MudPaper Elevation="2" Class="pa-4" Style="border-radius:12px;">
        <div class="d-flex justify-space-between align-center mb-4">
            <MudText Typo="Typo.h6">Nómina de Estudiantes (@_alumnos.Count)</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Save" OnClick="GuardarAsistencia" Disabled="_guardando">
                @if (_guardando) { <MudProgressCircular Class="ms-n1" Size="MudBlazor.Size.Small" Indeterminate="true" /> }
                else { <MudText>Guardar Asistencias</MudText> }
            </MudButton>
        </div>

        @if (_alumnos.Count == 0)
        {
            <MudAlert Severity="Severity.Warning">No hay estudiantes matriculados en esta sección.</MudAlert>
        }
        else
        {
            <MudTable Items="@_alumnos" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Código</MudTh>
                    <MudTh>Apellidos y Nombres</MudTh>
                    <MudTh Style="width:300px;">Estado de Asistencia</MudTh>
                    <MudTh>Observación</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.EstudianteCodigo</MudTd>
                    <MudTd Style="font-weight:600;">@context.EstudianteNombre</MudTd>
                    <MudTd>
                        <MudRadioGroup @bind-Value="context.Estado">
                            <MudRadio Value="EstadoAsistencia.Presente" Color="Color.Success" Size="MudBlazor.Size.Small">Presente</MudRadio>
                            <MudRadio Value="EstadoAsistencia.Tardanza" Color="Color.Warning" Size="MudBlazor.Size.Small">Tardanza</MudRadio>
                            <MudRadio Value="EstadoAsistencia.Falta" Color="Color.Error" Size="MudBlazor.Size.Small">Falta</MudRadio>
                            <MudRadio Value="EstadoAsistencia.JustificadoFalta" Color="Color.Info" Size="MudBlazor.Size.Small">Justific.</MudRadio>
                        </MudRadioGroup>
                    </MudTd>
                    <MudTd>
                        <MudTextField @bind-Value="context.Observacion" Placeholder="Nota opcional..." Variant="Variant.Text" Margin="Margin.Dense" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
}

@code {
    private List<SeccionDto> _secciones = new();
    private int _seccionSeleccionada = 0;
    private DateTime? _fechaSeleccionada = DateTime.Today;
    private bool _cargando = false;
    private bool _guardando = false;
    private List<AsistenciaDto>? _alumnos;

    protected override async Task OnInitializedAsync()
    {
        _secciones = await Mediator.Send(new GetSeccionesActivasQuery());
    }

    private void OnSeccionChanged()
    {
        _alumnos = null; // Reset lista cuando cambian de sección
    }

    private async Task CargarAlumnos()
    {
        if (_seccionSeleccionada == 0 || _fechaSeleccionada == null) return;
        
        _cargando = true;
        _alumnos = await Mediator.Send(new GetAsistenciaPorSeccionYFechaQuery
        {
            SeccionId = _seccionSeleccionada,
            Fecha = _fechaSeleccionada.Value
        });
        _cargando = false;
    }

    private async Task GuardarAsistencia()
    {
        if (_alumnos == null || _seccionSeleccionada == 0 || _fechaSeleccionada == null) return;

        _guardando = true;
        var result = await Mediator.Send(new SaveAsistenciaBatchCommand
        {
            SeccionId = _seccionSeleccionada,
            Fecha = _fechaSeleccionada.Value,
            Asistencias = _alumnos
        });
        _guardando = false;

        if (result)
        {
            Snackbar.Add("Asistencia guardada correctamente.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Hubo un error al guardar.", Severity.Error);
        }
    }
}
