@page "/personas/estudiantes"
@using ERP.Application.Features.Personas.Estudiantes
@using ERP.Domain.Enums
@using MediatR
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Estudiantes — ERP Educativo</PageTitle>

<MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
    <div>
        <MudText Typo="Typo.h5" Style="color:#1E1B4B; font-weight:700;">👨‍🎓 Estudiantes</MudText>
        <MudText Typo="Typo.body2" Style="color:#6B7280;">Directorio y gestión de estudiantes matriculados</MudText>
    </div>
    <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Color="MudBlazor.Color.Primary"
               OnClick="@(() => AbrirDialog(null))" Style="border-radius:8px;">Nuevo Estudiante</MudButton>
</MudStack>

<MudPaper Elevation="2" Style="border-radius:16px;">
    <MudTable Items="@_estudiantes" Dense="true" Hover="true" Loading="@_cargando"
              Filter="new Func<EstudianteDto,bool>(e => string.IsNullOrWhiteSpace(_search) || e.NombreCompleto.Contains(_search,StringComparison.OrdinalIgnoreCase) || e.Codigo.Contains(_search,StringComparison.OrdinalIgnoreCase) || e.DNI.Contains(_search))">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Directorio de Estudiantes</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_search" Placeholder="Buscar por nombre, código o DNI..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="MudBlazor.Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Código</MudTh><MudTh>Apellidos y Nombres</MudTh><MudTh>DNI</MudTh><MudTh>Teléfono</MudTh><MudTh>Estado</MudTh><MudTh>Acciones</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudText Typo="Typo.caption" Style="color:#6B7280;">@context.Codigo</MudText>
            </MudTd>
            <MudTd>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudAvatar Style="background:linear-gradient(135deg,#6B21A8,#F97316); font-size:0.75rem; width:32px; height:32px;">
                        @(context.Nombres.Length > 0 ? context.Nombres[0].ToString().ToUpper() : "E")
                    </MudAvatar>
                    <div>
                        <MudText Style="font-weight:600; font-size:0.875rem;">@context.NombreCompleto</MudText>
                        <MudText Typo="Typo.caption" Style="color:#9CA3AF;">@context.Email</MudText>
                    </div>
                </MudStack>
            </MudTd>
            <MudTd>@context.DNI</MudTd>
            <MudTd>@(context.Telefono ?? "—")</MudTd>
            <MudTd>
                <MudChip T="string" Size="MudBlazor.Size.Small"
                         Color="@(context.Estado == EstadoEstudiante.Activo ? MudBlazor.Color.Success : MudBlazor.Color.Default)">
                    @context.Estado.ToString()
                </MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="MudBlazor.Color.Info" Size="MudBlazor.Size.Small" Href="@($"/personas/estudiantes/detalle/{context.Id}")" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="MudBlazor.Color.Primary" Size="MudBlazor.Size.Small" OnClick="@(() => AbrirDialog(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="MudBlazor.Color.Error" Size="MudBlazor.Size.Small" OnClick="@(() => Eliminar(context.Id))" />
            </MudTd>
        </RowTemplate>
        <PagerContent><MudTablePager /></PagerContent>
    </MudTable>
</MudPaper>

@if (_dialogAbierto)
{
    <MudDialog @bind-Visible="_dialogAbierto" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
        <TitleContent><MudText Typo="Typo.h6">@(_form.Id > 0 ? "Editar" : "Nuevo") Estudiante</MudText></TitleContent>
        <DialogContent>
            <MudGrid>
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="_form.Codigo" Label="Código" Variant="Variant.Outlined" Required="true" /></MudItem>
                <MudItem xs="12" sm="8"><MudTextField @bind-Value="_form.DNI" Label="DNI / Documento" Variant="Variant.Outlined" Required="true" /></MudItem>
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="_form.Nombres" Label="Nombres" Variant="Variant.Outlined" Required="true" /></MudItem>
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="_form.ApellidoPaterno" Label="Apellido Paterno" Variant="Variant.Outlined" Required="true" /></MudItem>
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="_form.ApellidoMaterno" Label="Apellido Materno" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="12" sm="6"><MudDatePicker @bind-Date="_fechaNac" Label="Fecha de Nacimiento" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="TipoSexo" @bind-Value="_form.Sexo" Label="Sexo" Variant="Variant.Outlined">
                        @foreach (TipoSexo v in Enum.GetValues(typeof(TipoSexo))) { <MudSelectItem Value="@v">@v.ToString()</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6"><MudTextField @bind-Value="_form.Telefono" Label="Teléfono" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="12" sm="6"><MudTextField @bind-Value="_form.Email" Label="Correo Electrónico" InputType="InputType.Email" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_form.Direccion" Label="Dirección" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="EstadoEstudiante" @bind-Value="_form.Estado" Label="Estado" Variant="Variant.Outlined">
                        @foreach (EstadoEstudiante v in Enum.GetValues(typeof(EstadoEstudiante))) { <MudSelectItem Value="@v">@v.ToString()</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6"><MudTextField @bind-Value="_form.NombreApoderado" Label="Nombre del Apoderado" Variant="Variant.Outlined" /></MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _dialogAbierto = false)">Cancelar</MudButton>
            <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="Guardar">Guardar</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    private bool _cargando = true, _dialogAbierto = false;
    private string _search = "";
    private List<EstudianteDto> _estudiantes = new();
    private UpsertEstudianteCommand _form = new();
    private DateTime? _fechaNac = DateTime.Today.AddYears(-18);

    protected override async Task OnInitializedAsync() { await Cargar(); }

    async Task Cargar()
    {
        _cargando = true;
        _estudiantes = await Mediator.Send(new GetEstudiantesQuery());
        _cargando = false;
    }

    void AbrirDialog(EstudianteDto? e)
    {
        if (e == null)
        {
            _form = new(); _fechaNac = DateTime.Today.AddYears(-18);
        }
        else
        {
            _form = new UpsertEstudianteCommand { Id = e.Id, Codigo = e.Codigo, Nombres = e.Nombres, ApellidoPaterno = e.ApellidoPaterno, ApellidoMaterno = e.ApellidoMaterno, DNI = e.DNI, FechaNacimiento = e.FechaNacimiento, Sexo = e.Sexo, Telefono = e.Telefono, Email = e.Email, Estado = e.Estado };
            _fechaNac = e.FechaNacimiento;
        }
        _dialogAbierto = true;
    }

    async Task Guardar()
    {
        _form.FechaNacimiento = _fechaNac ?? DateTime.Today.AddYears(-18);
        try { await Mediator.Send(_form); Snackbar.Add("Guardado correctamente", Severity.Success); _dialogAbierto = false; await Cargar(); }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    async Task Eliminar(int id)
    {
        bool? ok = await DialogService.ShowMessageBoxAsync("Confirmar", "¿Eliminar este estudiante?", "Sí", "No");
        if (ok == true) { await Mediator.Send(new DeleteEstudianteCommand { Id = id }); Snackbar.Add("Eliminado", Severity.Success); await Cargar(); }
    }
}
