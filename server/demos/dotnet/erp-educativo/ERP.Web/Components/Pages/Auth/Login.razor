@page "/login"
@layout LoginLayout
@using MudBlazor

<PageTitle>Iniciar Sesión — ERP Educativo</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center">
    <MudPaper Elevation="4" Class="pa-8" Style="border-radius: 16px; width: 100%; max-width: 400px; background: white;">
        <MudStack AlignItems="AlignItems.Center" Spacing="4" Class="mb-6">
            <MudIcon Icon="@Icons.Material.Filled.School" Style="font-size: 3rem; color: #10B981;" />
            <MudText Typo="Typo.h5" Style="color: #1E1B4B; font-weight: 700;">ERP EDUCATIVO</MudText>
            <MudText Typo="Typo.body2" Style="color: #6B7280;">Ingresa tus credenciales para continuar</MudText>
        </MudStack>

        @if (!string.IsNullOrEmpty(Error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">Credenciales incorrectas o cuenta bloqueada.</MudAlert>
        }

        <form action="/account/login" method="post" data-enhance="false">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <MudStack Spacing="4">
                <MudTextField T="string" Name="email" Label="Correo Electrónico" Variant="Variant.Outlined" 
                              InputType="InputType.Email" Required="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
                
                <MudTextField T="string" Name="password" Label="Contraseña" Variant="Variant.Outlined" 
                              InputType="InputType.Password" Required="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />

                <div class="d-flex justify-space-between align-center">
                    <MudCheckBox T="bool" Label="Recordarme" Color="Color.Primary" Size="Size.Small" />
                    <MudLink Href="/forgot-password" Typo="Typo.body2" Color="Color.Primary">¿Olvidaste tu contraseña?</MudLink>
                </div>

                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Size="Size.Large" FullWidth="true" Style="border-radius: 8px; background: #1E1B4B; color: white;">
                    Iniciar Sesión
                </MudButton>
            </MudStack>
        </form>
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }
}
